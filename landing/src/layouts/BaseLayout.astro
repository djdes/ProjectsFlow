---
import '@fontsource-variable/inter';
// Моно-шрифт для dev-cool акцентов (eyebrow, терминал, метки). Разрешён в DESIGN.md (P0).
import '@fontsource-variable/jetbrains-mono';
import '@/styles/globals.css';
// Общие классы секций лендинга (P1, на токенах P0 — globals.css не трогаем).
import '@/styles/landing.css';

interface Props {
  title?: string;
  description?: string;
}

const SITE = 'https://projectsflow.ru/';
const {
  title = 'ProjectsFlow — доска задач для вайб-кодеров: воркер пишет код',
  description =
    'Доска задач для твоих проектов со встроенным AI-воркером, автоматизацией и финучётом. ' +
    'Бросаешь задачу в колонку worker — она выполняется по нашей подписке. Без своих ключей и лок-ина.',
} = Astro.props;
const ogImage = new URL('/og.png', SITE).href;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#06080d" />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={SITE} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ProjectsFlow" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:url" content={SITE} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="ProjectsFlow — доска задач для вайб-кодеров" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Анти-FOUC: тёмная тема выставляется до рендера React/island'ов. -->
    <script is:inline>
      document.documentElement.style.background = '#06080d';
    </script>

    <title>{title}</title>
  </head>
  <body>
    <slot />

    {/* ===== Чат-виджет помощи (P2) =====================================
        Остров создаёт P2 (HelpWidget*). Когда он появится в main — раскомментировать
        строку ниже (один импорт + монтаж снизу справа), island грузится отложенно.
        До готовности P2 — плейсхолдер, не блокируемся (см. план §3, §H п.12).
        TODO(P2): <HelpWidget client:idle /> + import в frontmatter. */}

    <script>
      // Auth-aware UI: чекаем /api/auth/me. 200 → выставляем html[data-auth="authed"],
      // CSS в landing.css переключает видимость [data-auth-anon]/[data-auth-authed].
      // На 401/ошибке ничего не делаем — дефолт уже anonymous.
      (async () => {
        try {
          const res = await fetch('/api/auth/me', { credentials: 'include' });
          if (!res.ok) return;
          document.documentElement.dataset.auth = 'authed';
        } catch {
          // Сеть недоступна или эндпоинт не отвечает — оставляем anonymous-дефолты.
        }
      })();
    </script>

    <script>
      // Глобальный scroll-reveal: вешает `.is-visible` когда элемент с `[data-reveal]`
      // попадает во вьюпорт. Один раз, без обратных переключений. Уважает reduced-motion.
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduceMotion && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
        );
        document.querySelectorAll('[data-reveal]').forEach((el) => io.observe(el));
      } else {
        document.querySelectorAll('[data-reveal]').forEach((el) => el.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
