---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import { readingMinutes, topicStyle, formatDate } from '@/lib/blog';

// Лендинг и SPA — один Express в prod; в dev можно указать PUBLIC_APP_URL.
const appBase = (import.meta.env.PUBLIC_APP_URL ?? '').replace(/\/+$/, '');

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const minutes = readingMinutes(post.body ?? '');
const st = topicStyle(post.data.topic);
// Оглавление: h2 как разделы, h3 — вложенные подпункты.
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<BaseLayout title={`${post.data.title} — Блог ProjectsFlow`} description={post.data.description}>
  <!-- Прогресс чтения: тонкая полоса сверху, заполняется по мере скролла статьи. -->
  <div class="read-progress" aria-hidden="true"><span data-read-bar></span></div>

  <Nav />
  <main id="main" class="post">
    <div class="pf-container">
      <a href="/blog" class="post__back">← Все статьи</a>

      <header class="post__head" data-reveal>
        <span class="post__topic" style={`color: ${st.ink}; background: ${st.gradient}`}>
          {post.data.topic}
        </span>
        <h1 class="post__title">{post.data.title}</h1>
        <p class="post__desc">{post.data.description}</p>
        <div class="post__meta">
          <span>{post.data.author}</span>
          <span class="post__dot" aria-hidden="true">·</span>
          <span>{formatDate(post.data.date)}</span>
          <span class="post__dot" aria-hidden="true">·</span>
          <span class="pf-mono">{minutes} мин чтения</span>
        </div>
      </header>

      <div class="post__cover" style={`background: ${st.gradient}`} aria-hidden="true">
        <span class="post__cover-word" style={`color: ${st.ink}`}>{post.data.title.split(' ')[0]}</span>
      </div>

      <div class="post__layout">
        <article class="post__content" data-reveal>
          <Content />
        </article>

        {
          toc.length > 1 && (
            <aside class="post__aside" aria-label="Содержание статьи">
              <nav class="post__toc" data-toc>
                <div class="post__toc-title">Содержание</div>
                <ul>
                  {toc.map((h) => (
                    <li class={h.depth === 3 ? 'post__toc-sub' : ''}>
                      <a href={`#${h.slug}`} data-toc-link={h.slug}>
                        {h.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </aside>
          )
        }
      </div>

      <div class="post__cta" data-reveal>
        <h2 class="post__cta-title">Хватит читать — попробуй сам</h2>
        <p class="post__cta-text">Опиши идею и получи первый результат в первый час. Без карты.</p>
        <a href={`${appBase}/register`} class="pf-btn pf-btn--primary pf-btn--lg pf-btn--invite">
          Начать бесплатно
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" aria-hidden="true">
            <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </a>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  /* Прогресс чтения */
  .read-progress {
    position: fixed;
    inset: 0 0 auto 0;
    height: 3px;
    z-index: 60;
    background: transparent;
    pointer-events: none;
  }
  .read-progress span {
    display: block;
    height: 100%;
    width: 0%;
    background: var(--grad-accent);
    box-shadow: 0 0 10px -1px var(--accent);
    transition: width 90ms linear;
  }

  .post { padding-top: var(--sp-12); padding-bottom: var(--section-y); }
  .post__back {
    display: inline-block;
    margin-bottom: var(--sp-6);
    font-size: var(--fs-sm);
    color: var(--muted);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease);
  }
  .post__back:hover { color: var(--accent); }

  .post__head { max-width: 46rem; }
  .post__topic {
    display: inline-block;
    padding: 3px 12px;
    border-radius: var(--r-full);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .post__title {
    margin-top: var(--sp-4);
    font-size: var(--fs-3xl);
    font-weight: 720;
    line-height: var(--lh-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--text);
    text-wrap: balance;
  }
  .post__desc {
    margin-top: var(--sp-4);
    font-size: var(--fs-lg);
    color: var(--muted);
    line-height: var(--lh-normal);
  }
  .post__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--sp-2);
    margin-top: var(--sp-6);
    font-size: var(--fs-sm);
    color: var(--dim);
  }
  .post__dot { opacity: 0.5; }

  .post__cover {
    position: relative;
    margin-top: var(--sp-8);
    height: clamp(180px, 30vw, 300px);
    border-radius: var(--r-lg);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    box-shadow: var(--shadow-lg);
  }
  .post__cover-word {
    font-size: clamp(4rem, 14vw, 9rem);
    font-weight: 800;
    letter-spacing: -0.05em;
    opacity: 0.16;
    padding-right: 0.15em;
    user-select: none;
    text-wrap: nowrap;
  }

  /* Раскладка: контент + правое sticky-оглавление */
  .post__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-12);
    margin-top: var(--sp-12);
  }
  @media (min-width: 1040px) {
    .post__layout { grid-template-columns: minmax(0, 1fr) 240px; align-items: start; }
  }

  .post__content { max-width: 46rem; }

  /* Проза (Markdown отрендерен через <Content/> — стилизуем через :global) */
  .post__content :global(h2) {
    margin-top: var(--sp-12);
    margin-bottom: var(--sp-3);
    font-size: var(--fs-2xl);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    line-height: var(--lh-snug);
    color: var(--text);
    scroll-margin-top: 90px;
    text-wrap: balance;
  }
  .post__content :global(h3) {
    margin-top: var(--sp-8);
    margin-bottom: var(--sp-2);
    font-size: var(--fs-lg);
    font-weight: 650;
    color: var(--text);
    scroll-margin-top: 90px;
  }
  .post__content :global(p) {
    margin-block: var(--sp-4);
    font-size: var(--fs-base);
    line-height: 1.75;
    color: var(--muted);
  }
  .post__content :global(strong) { color: var(--text); font-weight: 650; }
  .post__content :global(a) { color: var(--accent-deep); text-decoration: underline; text-underline-offset: 2px; }
  .post__content :global(ul),
  .post__content :global(ol) { margin-block: var(--sp-4); padding-left: 1.3rem; display: flex; flex-direction: column; gap: var(--sp-2); }
  .post__content :global(li) { font-size: var(--fs-base); line-height: 1.65; color: var(--muted); }
  .post__content :global(li)::marker { color: var(--accent); }
  .post__content :global(blockquote) {
    margin-block: var(--sp-6);
    padding: var(--sp-4) var(--sp-6);
    border-left: 3px solid var(--accent);
    background: var(--accent-soft);
    border-radius: 0 var(--r) var(--r) 0;
    font-size: var(--fs-lg);
    font-style: italic;
    color: var(--text);
  }
  .post__content :global(blockquote p) { margin: 0; color: var(--text); }
  .post__content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    padding: 1px 6px;
    border-radius: var(--r-sm);
    background: var(--surface-2);
    color: var(--accent-deep);
  }

  /* Оглавление */
  .post__aside { display: none; }
  @media (min-width: 1040px) { .post__aside { display: block; } }
  .post__toc { position: sticky; top: 90px; }
  .post__toc-title {
    font-size: var(--fs-xs);
    font-weight: 700;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--dim);
    margin-bottom: var(--sp-3);
  }
  .post__toc ul { list-style: none; margin: 0; padding: 0; border-left: 1px solid var(--line); }
  .post__toc li { margin: 0; }
  .post__toc-sub a { padding-left: var(--sp-6) !important; font-size: var(--fs-xs) !important; }
  .post__toc a {
    display: block;
    padding: 6px var(--sp-3);
    margin-left: -1px;
    border-left: 2px solid transparent;
    font-size: var(--fs-sm);
    line-height: 1.35;
    color: var(--muted);
    text-decoration: none;
    transition: color var(--dur) var(--ease), border-color var(--dur) var(--ease);
  }
  .post__toc a:hover { color: var(--text); }
  .post__toc a.is-active {
    color: var(--accent-deep);
    border-left-color: var(--accent);
    font-weight: 600;
  }

  /* CTA в конце статьи */
  .post__cta {
    max-width: 46rem;
    margin-top: var(--sp-16);
    padding: var(--sp-8);
    border: 1px solid var(--accent-line);
    border-radius: var(--r-lg);
    background: var(--accent-soft);
    text-align: center;
  }
  .post__cta-title { font-size: var(--fs-xl); font-weight: 700; color: var(--text); letter-spacing: var(--tracking-tight); }
  .post__cta-text { margin-top: var(--sp-2); margin-bottom: var(--sp-6); color: var(--muted); }
</style>

<script>
  // 1) Прогресс-бар чтения: доля прокрутки в пределах статьи.
  const bar = document.querySelector<HTMLElement>('[data-read-bar]');
  const article = document.querySelector<HTMLElement>('.post__content');
  if (bar && article) {
    const update = (): void => {
      const rect = article.getBoundingClientRect();
      const total = rect.height - window.innerHeight;
      const scrolled = -rect.top;
      const pct = total > 0 ? Math.min(100, Math.max(0, (scrolled / total) * 100)) : 0;
      bar.style.width = `${pct}%`;
    };
    update();
    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update, { passive: true });
  }

  // 2) Подсветка активного пункта оглавления при скролле (плавно, через CSS-переходы).
  const tocLinks = new Map<string, HTMLAnchorElement>();
  document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]').forEach((a) => {
    const id = a.getAttribute('data-toc-link');
    if (id) tocLinks.set(id, a);
  });

  if (tocLinks.size > 0) {
    const heads = Array.from(tocLinks.keys())
      .map((id) => document.getElementById(id))
      .filter((el): el is HTMLElement => el !== null);

    let activeId = '';
    const setActive = (id: string): void => {
      if (id === activeId) return;
      activeId = id;
      tocLinks.forEach((a, key) => a.classList.toggle('is-active', key === id));
    };

    const io = new IntersectionObserver(
      (entries) => {
        // Активен самый верхний заголовок, попавший в «полосу чтения» у верха экрана.
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (visible[0]) setActive(visible[0].target.id);
      },
      { rootMargin: '-84px 0px -66% 0px', threshold: 0 },
    );
    heads.forEach((h) => io.observe(h));

    // Стартовое состояние — первый заголовок.
    if (heads[0]) setActive(heads[0].id);
  }
</script>
