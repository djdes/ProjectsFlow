---
// Новый нарратив: от заведения проекта до самостоятельной работы автоматизации и финучёта.
const steps = [
  {
    n: '01',
    title: 'Заводишь проект',
    body: 'Имя, ссылка на GitHub-репозиторий — и всё. Никаких 20 полей в форме.',
  },
  {
    n: '02',
    title: 'Подключаешь GitHub',
    body: 'Device Flow без копипасты client_secret. Коммиты подтягиваются и привязываются к задачам.',
  },
  {
    n: '03',
    title: 'Бросаешь задачи воркеру',
    body: 'Кидаешь задачу в колонку worker — AI пишет код, коммитит и деплоит по нашей подписке.',
  },
  {
    n: '04',
    title: 'Автоматизация и деньги — сами',
    body: 'Диспетчер генерит задачи по твоим критериям, а финучёт считает расход по проекту в рублях.',
  },
];
---

<section id="how" class="pf-section">
  <div class="pf-container">
    <div class="how__head" data-reveal>
      <div class="pf-stag">// как это работает</div>
      <h2 class="pf-h2">Четыре шага — и&nbsp;проект двигается сам</h2>
      <p class="pf-lead">
        От пустого репозитория до автономного потока задач. Без настройки CI и возни с ключами.
      </p>
    </div>

    <ol class="how__grid">
      <span class="step-connector how__connector" aria-hidden="true"></span>
      {
        steps.map((s, i) => (
          <li class="how__step" data-reveal style={`--reveal-delay: ${i * 110}ms`}>
            <div class="pf-mono how__num">{s.n}</div>
            <h3 class="how__title">{s.title}</h3>
            <p class="how__body">{s.body}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .how__head { max-width: 40rem; }
  .how__grid {
    position: relative;
    list-style: none;
    margin: var(--sp-12) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-4);
  }
  @media (min-width: 640px) {
    .how__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .how__grid { grid-template-columns: repeat(4, 1fr); }
  }

  /* Анимированный коннектор — только на десктопе (4 в ряд). */
  .how__connector {
    display: none;
  }
  @media (min-width: 1024px) {
    .how__connector {
      display: block;
      top: 2.6rem;
      left: 8%;
      right: 8%;
      height: 1px;
    }
  }

  .how__step {
    position: relative;
    padding: var(--sp-6);
    border: 1px solid var(--line);
    border-radius: var(--r);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.02), transparent);
  }
  .how__num {
    font-size: var(--fs-sm);
    letter-spacing: 0.18em;
    color: var(--accent);
  }
  .how__title {
    margin-top: var(--sp-3);
    font-size: var(--fs-lg);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    color: var(--text);
  }
  .how__body {
    margin-top: var(--sp-2);
    font-size: var(--fs-sm);
    line-height: var(--lh-normal);
    color: var(--muted);
  }
</style>
