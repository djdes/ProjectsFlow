---
const steps = [
  {
    n: '01',
    title: 'Заводишь проект',
    body: 'Имя, ссылка на репозиторий, опционально — статус. Никаких 20 полей в форме.',
  },
  {
    n: '02',
    title: 'Подключаешь GitHub и KB',
    body: 'Device Flow для GitHub — без копипасты client_secret. KB живёт в твоём приватном репозитории.',
  },
  {
    n: '03',
    title: 'Документируешь и не теряешь',
    body: 'Через полгода открываешь проект — видишь стек, секреты, последние коммиты, открытые задачи. Сразу.',
  },
];
---

<section id="how" class="relative py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <span class="eyebrow">Как это работает</span>
      <h2 class="mt-5 text-balance text-3xl font-semibold tracking-tight text-ink-50 sm:text-5xl">
        Три шага — и&nbsp;проект больше не&nbsp;«где-то в&nbsp;голове»
      </h2>
    </div>

    <ol class="relative mt-16 grid gap-px overflow-hidden rounded-2xl bg-white/5 sm:grid-cols-3">
      <!-- Анимированная линия-коннектор через всю строку (только sm+, на мобиле скрыта). -->
      <span
        class="step-connector pointer-events-none hidden sm:block"
        style="top: 50%; left: 12%; right: 12%; height: 1px; transform: translateY(-50%);"
        aria-hidden="true"
      ></span>

      {
        steps.map((s, i) => (
          <li
            class="relative bg-ink-900 p-8"
            data-reveal
            style={`--reveal-delay: ${i * 120}ms`}
          >
            <div class="font-mono text-xs tracking-widest text-accent-400">{s.n}</div>
            <h3 class="mt-3 text-lg font-semibold tracking-tight text-ink-50">{s.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-200">{s.body}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
