---
// Нарратив для вайб-кодера: от идеи до запуска, языком результата — без техники.
const steps = [
  {
    n: '01',
    title: 'Опиши идею',
    body: 'Просто словами расскажи, что хочешь получить. Никаких форм с двадцатью полями.',
  },
  {
    n: '02',
    title: 'AI берётся за дело',
    body: 'Платформа разбивает задумку на задачи и доводит их до готового результата сама.',
  },
  {
    n: '03',
    title: 'Смотришь, как растёт',
    body: 'Видишь прогресс в реальном времени и сколько всё стоит — прозрачно, в рублях.',
  },
  {
    n: '04',
    title: 'Запускаешь',
    body: 'Готовый продукт — у тебя на руках. Дальше развивай новыми идеями, когда захочешь.',
  },
];
---

<section id="how" class="pf-section how">
  <div class="pf-container">
    <div class="how__head" data-reveal>
      <div class="pf-stag">Как это работает</div>
      <h2 class="pf-h2">Четыре шага — от идеи до запуска</h2>
      <p class="pf-lead">
        Ты остаёшься на уровне идей и решений. Всё, что между задумкой и готовым продуктом,
        платформа берёт на себя.
      </p>
    </div>

    <ol class="how__grid">
      <span class="step-connector how__connector" aria-hidden="true"></span>
      {
        steps.map((s, i) => (
          <li class="how__step" data-reveal style={`--reveal-delay: ${i * 110}ms`}>
            <div class="pf-mono how__num">{s.n}</div>
            <h3 class="how__title">{s.title}</h3>
            <p class="how__body">{s.body}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  /* Контрастная глава — тёплый бумажный фон чередования. */
  .how { background: var(--bg-alt); }

  .how__head { max-width: 40rem; }
  .how__grid {
    position: relative;
    list-style: none;
    margin: var(--sp-12) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-4);
  }
  @media (min-width: 640px) {
    .how__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .how__grid { grid-template-columns: repeat(4, 1fr); }
  }

  /* Анимированный коннектор — только на десктопе (4 в ряд).
     Едва заметная холодная линия вместо яркого циана из тёмной эпохи. */
  .how__connector {
    display: none;
  }
  @media (min-width: 1024px) {
    .how__connector {
      display: block;
      top: 2.6rem;
      left: 8%;
      right: 8%;
      height: 1px;
      background: linear-gradient(
        90deg,
        transparent,
        var(--accent-line) 50%,
        transparent
      );
    }
  }

  .how__step {
    position: relative;
    padding: var(--sp-6);
    border: 1px solid var(--line);
    border-radius: var(--r-md);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--dur) var(--ease), border-color var(--dur) var(--ease);
  }
  @media (prefers-reduced-motion: no-preference) {
    .how__step:hover {
      border-color: var(--line-strong);
      box-shadow: var(--shadow);
    }
  }
  .how__num {
    font-size: var(--fs-sm);
    letter-spacing: 0.18em;
    color: var(--accent);
  }
  .how__title {
    margin-top: var(--sp-3);
    font-size: var(--fs-lg);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    color: var(--text);
  }
  .how__body {
    margin-top: var(--sp-2);
    font-size: var(--fs-sm);
    line-height: var(--lh-normal);
    color: var(--muted);
  }
</style>
