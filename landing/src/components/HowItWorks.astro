---
// Нарратив для вайб-кодера: от идеи до запуска, языком результата — без техники.
const steps = [
  {
    n: '01',
    title: 'Опиши идею',
    body: 'Просто словами расскажи, что хочешь получить. Никаких форм с двадцатью полями.',
  },
  {
    n: '02',
    title: 'AI берётся за дело',
    body: 'Платформа разбивает задумку на задачи и доводит их до готового результата сама.',
  },
  {
    n: '03',
    title: 'Смотришь, как растёт',
    body: 'Видишь прогресс в реальном времени и сколько всё стоит — прозрачно, в рублях.',
  },
  {
    n: '04',
    title: 'Запускаешь',
    body: 'Готовый продукт — у тебя на руках. Дальше развивай новыми идеями, когда захочешь.',
  },
];

// Пастельные тона шагов — та же палитра «живости», что и в фичах.
const tones = [
  { bg: '#e9f1fc', accent: '#2f6fd4', line: 'rgba(47, 111, 212, 0.20)' },
  { bg: '#efe9fd', accent: '#7c5cff', line: 'rgba(124, 92, 255, 0.20)' },
  { bg: '#fdefda', accent: '#c9760a', line: 'rgba(201, 118, 10, 0.22)' },
  { bg: '#ddf2ea', accent: '#0f9d77', line: 'rgba(15, 157, 119, 0.22)' },
];
---

<section id="how" class="pf-section how">
  <div class="pf-container">
    <div class="how__head" data-reveal>
      <div class="pf-stag">Как это работает</div>
      <h2 class="pf-h2">Четыре шага — от идеи до запуска</h2>
      <p class="pf-lead">
        Ты остаёшься на уровне идей и решений. Всё, что между задумкой и готовым продуктом,
        платформа берёт на себя.
      </p>
    </div>

    <ol class="how__grid">
      <span class="step-connector how__connector" aria-hidden="true"></span>
      {
        steps.map((s, i) => (
          <li
            class="how__step"
            data-reveal
            style={`--reveal-delay: ${i * 110}ms; --tone-bg: ${tones[i].bg}; --tone-accent: ${tones[i].accent}; --tone-line: ${tones[i].line}`}
          >
            <div class="pf-mono how__num">{s.n}</div>
            <h3 class="how__title">{s.title}</h3>
            <p class="how__body">{s.body}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  /* Контрастная глава — тёплый бумажный фон чередования. */
  .how { background: var(--bg-alt); }

  .how__head { max-width: 40rem; }
  .how__grid {
    position: relative;
    list-style: none;
    margin: var(--sp-12) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-4);
  }
  @media (min-width: 640px) {
    .how__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .how__grid { grid-template-columns: repeat(4, 1fr); }
  }

  /* Коннектор убран: цветные панели-шаги сами читаются как последовательность. */
  .how__connector { display: none; }

  .how__step {
    position: relative;
    padding: clamp(1.5rem, 2.5vw, 2rem);
    border: 1px solid var(--tone-line, var(--line));
    border-radius: var(--r-lg);
    background: var(--tone-bg, var(--surface));
    transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
  }
  @media (prefers-reduced-motion: no-preference) {
    .how__step:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow);
    }
  }
  .how__num {
    font-size: var(--fs-lg);
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--tone-accent, var(--accent));
  }
  .how__title {
    margin-top: var(--sp-3);
    font-size: var(--fs-lg);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    color: var(--text);
  }
  .how__body {
    margin-top: var(--sp-2);
    font-size: var(--fs-sm);
    line-height: var(--lh-normal);
    color: var(--muted);
  }
</style>
