---
// CTA-блок: пара кнопок «Создать аккаунт» + «Войти», auth-aware.
// URL'ы относительные — лендинг и SPA отдаются одним Express'ом (см. server/src/presentation/http.ts).
// Для dev'а (Astro :4321 ≠ Vite :5173) можно задать `PUBLIC_APP_URL` в .env лендинга.

const appBase = (import.meta.env.PUBLIC_APP_URL ?? '').replace(/\/+$/, '');

interface Props {
  size?: 'lg' | 'md';
}
const { size = 'lg' } = Astro.props as Props;
const sizeCls = size === 'lg' ? 'pf-btn--lg' : '';
---

<div class="authcta">
  {/* Anonymous (default) */}
  <a href={`${appBase}/register`} data-auth-anon class:list={['pf-btn', 'pf-btn--primary', sizeCls]}>
    Создать аккаунт
    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" class="authcta__arrow" aria-hidden="true">
      <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  </a>
  <a href={`${appBase}/login`} data-auth-anon class:list={['pf-btn', 'pf-btn--ghost', sizeCls]}>
    Войти
  </a>
  {/* Authed (toggled by BaseLayout script) */}
  <a
    href={`${appBase}/`}
    data-auth-authed
    class:list={['pf-btn', 'pf-btn--primary', sizeCls, 'authcta__authed']}
  >
    Открыть приложение
    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" class="authcta__arrow" aria-hidden="true">
      <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  </a>
</div>

<style>
  .authcta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--sp-3);
  }
  .authcta__arrow { width: 16px; height: 16px; }
  .authcta__authed { display: none; }
</style>
