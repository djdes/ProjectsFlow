---
// «Внутри продукта» — Notion-style бенто. РЕАЛЬНЫЕ скрины приложения (3360×1900, 2×),
// ОБРЕЗАННЫЕ до отдельных панелей и показанные крупно → чётко (исходников с запасом).
// Обрезка — через .shot (overflow + позиционирование img: --zoom масштаб, --x/--y сдвиг).
// Живой воркер и чек-лист — вёрстка (для них нет отдельного скрина).

const workerLog = [
  { k: 'c', text: '// PF-219 · Собрать лендинг для запуска' },
  { k: 'p', text: '$ читаю ТЗ и структуру проекта' },
  { k: 'v', text: '→ создаю Hero, Features, Pricing' },
  { k: 'p', text: '$ пишу код компонентов' },
  { k: 'v', text: '→ верстаю адаптив, подключаю токены' },
  { k: 'p', text: '$ прогоняю сборку и линтер' },
];

const checks = [
  { label: 'Сборка проходит без ошибок', done: true },
  { label: 'Линтер и типы — чисто', done: true },
  { label: 'Секреты не попали в код', done: true },
  { label: 'Адаптив на телефоне', done: true },
];

const examples = [
  'Собери лендинг для запуска',
  'Добавь экран оплаты',
  'Сделай тёмную тему',
  'Подключи Telegram-бота',
  'Почини баг и выкати',
  'Автоматизируй рутину проекта',
];
---

<section id="product" class="pf-section shots">
  <div class="pf-container">
    <div class="shots__head" data-reveal>
      <div class="pf-stag">Внутри продукта</div>
      <h2 class="pf-h2">Как это выглядит в&nbsp;работе</h2>
      <p class="pf-lead">
        Настоящий интерфейс — по кусочку: доска, живой воркер, деньги и проверки.
        Не картинки-заглушки, а реальные экраны продукта.
      </p>
    </div>

    <div class="shots__bento">
      <!-- Доска — реальный скрин, обрезан до колонок -->
      <article class="shots__panel shots__panel--blue shots__panel--wide" data-reveal>
        <div class="shots__panel-head">
          <h3 class="shots__panel-title">Доску ведёт AI</h3>
          <p class="shots__panel-sub">Колонки Черновики → Воркер → Готово. Бросил задачу — AI берёт и доводит.</p>
        </div>
        <div class="shot" style="--img:url(/shots/app-board.png); --ar:54%; --zoom:152%; --pos:57% 27%" role="img" aria-label="Доска задач ProjectsFlow: колонки и карточки"></div>
      </article>

      <!-- Живой воркер — вёрстка (нет отдельного скрина) -->
      <article class="shots__panel shots__panel--violet" data-reveal>
        <div class="shots__panel-head">
          <h3 class="shots__panel-title">Видно каждый шаг</h3>
          <p class="shots__panel-sub">Живой лог: что AI делает и во что обходится — до копейки.</p>
        </div>
        <div class="mock mock--lift" data-theme="dark">
          <div class="mock__chrome">
            <span class="mock__dot mock__dot--r"></span>
            <span class="mock__dot mock__dot--y"></span>
            <span class="mock__dot mock__dot--g"></span>
            <span class="mock__crumb mock__crumb--mono">worker · PF-219</span>
          </div>
          <div class="mock__body term" role="img" aria-label="Живой лог AI-воркера">
            <div class="term__log">
              {workerLog.map((line) => (
                <span class:list={['term__line', `term__line--${line.k}`]}>{line.text}</span>
              ))}
              <span class="term__line term__line--live">
                <span class="term__caret" aria-hidden="true"></span> собираю production-бандл…
              </span>
            </div>
            <div class="term__foot">
              <div class="term__progress"><span style="width:84%"></span></div>
              <div class="term__meta">
                <span class="term__cost">84% · 3.20&nbsp;₽</span>
                <span class="term__status">В работе</span>
              </div>
            </div>
          </div>
        </div>
      </article>

      <!-- Финансы — реальный скрин, обрезан до сводки -->
      <article class="shots__panel shots__panel--green" data-reveal>
        <div class="shots__panel-head">
          <h3 class="shots__panel-title">Деньги с одного взгляда</h3>
          <p class="shots__panel-sub">Доход, расход и прибыль по проекту — в рублях.</p>
        </div>
        <div class="shot" style="--img:url(/shots/app-finance.png); --ar:30%; --zoom:225%; --pos:62% 11%" role="img" aria-label="Финансы: доход, зарплаты, расходы, прибыль"></div>
      </article>

      <!-- Финансы — детали (обрезано до карточки расходов/доходов) -->
      <article class="shots__panel shots__panel--peach" data-reveal>
        <div class="shots__panel-head">
          <h3 class="shots__panel-title">Расходы и доходы — по строкам</h3>
          <p class="shots__panel-sub">Каждая трата и оплата — с суммой, категорией и датой.</p>
        </div>
        <div class="shot" style="--img:url(/shots/app-finance.png); --ar:56%; --zoom:205%; --pos:64% 46%" role="img" aria-label="Прочие расходы и доходы по строкам"></div>
      </article>

      <!-- Колонка «Воркер» + «Готово» — обрезано из доски -->
      <article class="shots__panel shots__panel--amber shots__panel--wide" data-reveal>
        <div class="shots__panel-head">
          <h3 class="shots__panel-title">Колонка «Воркер · Claude Opus»</h3>
          <p class="shots__panel-sub">Перетащил задачу сюда — AI берёт в работу и переносит в «Готово».</p>
        </div>
        <div class="shot" style="--img:url(/shots/app-board.png); --ar:42%; --zoom:270%; --pos:84% 24%" role="img" aria-label="Колонки Воркер и Готово с задачами"></div>
      </article>

      <!-- Автопроверки — вёрстка -->
      <article class="shots__panel shots__panel--coral" data-reveal>
        <div class="shots__panel-head">
          <h3 class="shots__panel-title">Проверки перед выкаткой</h3>
          <p class="shots__panel-sub">Сборка, линтер, секреты — зелёные галочки, можно катить.</p>
        </div>
        <div class="mock mock--lift">
          <div class="mock__chrome">
            <span class="mock__dot mock__dot--r"></span>
            <span class="mock__dot mock__dot--y"></span>
            <span class="mock__dot mock__dot--g"></span>
            <span class="mock__crumb">PF-219 · Перед выкаткой</span>
          </div>
          <div class="mock__body checks" role="img" aria-label="Чек-лист автопроверок">
            <div class="checks__head">
              <span class="checks__title">Автопроверки</span>
              <span class="checks__badge">4 из 4</span>
            </div>
            <ul class="checks__list">
              {checks.map((c) => (
                <li class="checks__item">
                  <span class="checks__mark" aria-hidden="true">
                    <svg viewBox="0 0 16 16" width="14" height="14" fill="none">
                      <path d="M3.5 8.5l3 3 6-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </span>
                  <span class="checks__label">{c.label}</span>
                  <span class="checks__ok">ОК</span>
                </li>
              ))}
            </ul>
            <div class="checks__foot"><span class="checks__ready">Готово к выкатке</span></div>
          </div>
        </div>
      </article>
    </div>

    <div class="shots__examples" data-reveal>
      <div class="pf-stag shots__examples-tag">Примеры: что можно поручить</div>
      <div class="shots__examples-grid">
        {
          examples.map((e) => (
            <div class="shots__example">
              <span class="shots__example-q">«{e}»</span>
              <span class="shots__example-go">→ берём в работу</span>
            </div>
          ))
        }
      </div>
      <p class="shots__examples-note">
        Просто опиши задачу словами — остальное платформа берёт на себя.
      </p>
    </div>
  </div>
</section>

<style>
  .shots__head { max-width: 42rem; }

  /* --- Бенто панелей (как у Notion) --- */
  .shots__bento {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-5);
    margin-top: var(--sp-12);
  }
  @media (min-width: 900px) {
    .shots__bento { grid-template-columns: repeat(12, 1fr); gap: var(--sp-6); }
    .shots__panel { grid-column: span 6; }
    .shots__panel--wide { grid-column: span 7; }
    .shots__panel--violet { grid-column: span 5; }
    .shots__panel--coral { grid-column: span 5; }
  }

  .shots__panel {
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
    padding: clamp(1.25rem, 2.4vw, 2rem);
    border-radius: var(--r-lg);
    border: 1px solid var(--tone-line, var(--line));
    background: var(--tone-bg, var(--surface));
    overflow: hidden;
  }
  .shots__panel--blue { --tone-bg: #dbeaf7; --tone-line: rgba(47, 111, 212, 0.18); }
  .shots__panel--violet { --tone-bg: #e7e1fa; --tone-line: rgba(124, 92, 255, 0.18); }
  .shots__panel--green { --tone-bg: #cfebe0; --tone-line: rgba(18, 169, 123, 0.20); }
  .shots__panel--peach { --tone-bg: #fbe9d7; --tone-line: rgba(201, 118, 10, 0.20); }
  .shots__panel--amber { --tone-bg: #fbeecb; --tone-line: rgba(183, 121, 31, 0.22); }
  .shots__panel--coral { --tone-bg: #fbddd4; --tone-line: rgba(224, 93, 67, 0.20); }

  .shots__panel-head { max-width: 32rem; }
  .shots__panel-title { font-size: var(--fs-xl); font-weight: 700; letter-spacing: var(--tracking-tight); color: var(--text); }
  .shots__panel-sub { margin-top: var(--sp-2); font-size: var(--fs-sm); line-height: var(--lh-normal); color: var(--muted); }

  /* --- Обрезанный реальный скрин: крупно и чётко (background-crop) ---
     --img: url скрина; --ar: пропорция окна (высота/ширина); --zoom: background-size
     (масштаб, >100% = ближе); --pos: background-position (какую часть показать). */
  .shot {
    position: relative;
    margin-top: auto;
    border-radius: var(--r);
    border: 1px solid rgba(11, 18, 32, 0.08);
    background-color: var(--surface);
    background-image: var(--img);
    background-repeat: no-repeat;
    background-size: var(--zoom, cover);
    background-position: var(--pos, center);
    box-shadow:
      0 1px 2px rgba(11, 18, 32, 0.05),
      0 18px 38px -18px rgba(11, 18, 32, 0.22);
  }
  .shot::before { content: ''; display: block; padding-top: var(--ar, 56%); }

  /* --- Оконная рамка (терминал/чек-лист) --- */
  .mock { border: 1px solid var(--line); border-radius: var(--r); background: var(--surface); overflow: hidden; box-shadow: 0 1px 2px rgba(11, 18, 32, 0.05), 0 18px 38px -18px rgba(11, 18, 32, 0.22); margin-top: auto; }
  .mock__chrome { display: flex; align-items: center; gap: var(--sp-2); height: 34px; padding-inline: var(--sp-3); border-bottom: 1px solid var(--line); background: var(--surface-2); }
  .mock__dot { width: 10px; height: 10px; border-radius: 50%; flex: none; }
  .mock__dot--r { background: var(--danger); }
  .mock__dot--y { background: var(--warn); }
  .mock__dot--g { background: var(--signal); }
  .mock__crumb { margin-left: var(--sp-2); font-size: var(--fs-xs); color: var(--dim); }
  .mock__crumb--mono { font-family: var(--font-mono); }
  .mock__body { padding: var(--sp-4); }
  .mock[data-theme='dark'] { --surface-2: var(--dark-bg); }

  .term { display: flex; flex-direction: column; gap: var(--sp-4); }
  .term__log { display: flex; flex-direction: column; gap: 6px; font-family: var(--font-mono); font-size: 12.5px; line-height: 1.6; }
  .term__line { color: var(--muted); white-space: pre-wrap; word-break: break-word; }
  .term__line--c { color: var(--dim); }
  .term__line--p { color: var(--signal); }
  .term__line--v { color: var(--accent-bright); }
  .term__line--live { color: var(--text); display: inline-flex; align-items: center; gap: 7px; }
  .term__caret { width: 7px; height: 13px; border-radius: 1px; background: var(--accent-bright); box-shadow: 0 0 10px var(--accent-bright); flex: none; }
  @media (prefers-reduced-motion: no-preference) {
    .term__caret { animation: pf-caret-blink 1.1s steps(1) infinite; }
  }
  @keyframes pf-caret-blink { 0%, 50% { opacity: 1; } 50.01%, 100% { opacity: 0.15; } }
  .term__foot { display: flex; flex-direction: column; gap: var(--sp-2); }
  .term__progress { height: 6px; border-radius: var(--r-full); background: var(--surface-2); overflow: hidden; }
  .term__progress span { display: block; height: 100%; background: var(--grad-accent); position: relative; overflow: hidden; transition: width 0.8s ease; }
  .term__meta { display: flex; align-items: center; justify-content: space-between; font-family: var(--font-mono); font-size: var(--fs-xs); }
  .term__cost { color: var(--accent-bright); font-weight: 600; }
  .term__status { color: var(--warn); display: inline-flex; align-items: center; gap: 5px; }
  .term__status::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--warn); }

  .checks { display: flex; flex-direction: column; gap: var(--sp-3); }
  .checks__head { display: flex; align-items: center; justify-content: space-between; }
  .checks__title { font-size: var(--fs-base); font-weight: 700; color: var(--text); }
  .checks__badge { font-family: var(--font-mono); font-size: var(--fs-xs); font-weight: 600; color: var(--signal); background: var(--surface-2); border: 1px solid var(--line); border-radius: var(--r-full); padding: 2px 10px; }
  .checks__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--sp-2); }
  .checks__item { display: flex; align-items: center; gap: var(--sp-3); padding: var(--sp-3); border: 1px solid var(--line); border-radius: var(--r-sm); background: var(--surface-2); }
  .checks__mark { flex: none; width: 22px; height: 22px; border-radius: var(--r-full); display: grid; place-items: center; color: var(--surface); background: var(--signal); }
  .checks__label { flex: 1; font-size: var(--fs-sm); color: var(--text); }
  .checks__ok { font-family: var(--font-mono); font-size: 11px; font-weight: 700; color: var(--signal); }
  .checks__foot { display: flex; align-items: center; padding-top: var(--sp-1); }
  .checks__ready { font-size: var(--fs-sm); font-weight: 600; color: var(--signal); display: inline-flex; align-items: center; gap: 7px; }
  .checks__ready::before { content: ''; width: 8px; height: 8px; border-radius: 50%; background: var(--signal); box-shadow: 0 0 8px var(--signal); }

  @media (prefers-reduced-motion: no-preference) {
    .term__progress span::after { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.55), transparent); transform: translateX(-100%); animation: term-shimmer 1.9s ease-in-out infinite; }
    @keyframes term-shimmer { 0% { transform: translateX(-100%); } 55%, 100% { transform: translateX(320%); } }
    .checks__mark { animation: checks-pop 4.5s ease-in-out infinite; }
    .checks__item:nth-child(2) .checks__mark { animation-delay: 0.4s; }
    .checks__item:nth-child(3) .checks__mark { animation-delay: 0.8s; }
    .checks__item:nth-child(4) .checks__mark { animation-delay: 1.2s; }
    @keyframes checks-pop { 0%, 82%, 100% { transform: scale(1); } 88% { transform: scale(1.22); } }
    .checks__ready::before { animation: ready-pulse 2s ease-in-out infinite; }
    @keyframes ready-pulse { 0%, 100% { opacity: 1; box-shadow: 0 0 8px var(--signal); } 50% { opacity: 0.6; box-shadow: 0 0 2px var(--signal); } }
  }

  /* --- Примеры использования --- */
  .shots__examples { margin-top: var(--sp-16); text-align: center; }
  .shots__examples-tag { display: block; }
  .shots__examples-grid { display: grid; grid-template-columns: 1fr; gap: var(--sp-3); margin-top: var(--sp-6); }
  @media (min-width: 640px) { .shots__examples-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .shots__examples-grid { grid-template-columns: repeat(3, 1fr); } }
  .shots__example { display: flex; flex-direction: column; gap: var(--sp-1); padding: var(--sp-4); border: 1px solid var(--line); border-radius: var(--r); background: var(--surface); box-shadow: var(--shadow-sm); text-align: left; transition: border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease); }
  @media (prefers-reduced-motion: no-preference) {
    .shots__example:hover { border-color: var(--accent-line); box-shadow: var(--shadow); }
  }
  .shots__example-q { font-size: var(--fs-base); font-weight: 600; color: var(--text); }
  .shots__example-go { font-size: var(--fs-xs); color: var(--accent); }
  .shots__examples-note { margin-top: var(--sp-6); font-size: var(--fs-sm); color: var(--muted); }
</style>

<script>
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const bar = document.querySelector<HTMLElement>('.term__progress span');
    const cost = document.querySelector<HTMLElement>('.term__cost');
    if (bar && cost) {
      let pct = 84;
      setInterval(() => {
        pct += Math.random() < 0.75 ? 1 : 0;
        if (pct >= 98) pct = 71;
        bar.style.width = `${pct}%`;
        cost.textContent = `${pct}% · ${(pct * 0.038).toFixed(2)} ₽`;
      }, 950);
    }
  }
</script>
