---
// Главная витрина продукта. Доска и финансы — РЕАЛЬНЫЕ скриншоты прод-приложения
// (снятые Playwright'ом с изолированного демо-проекта), лежат в /public/shots/.
// Живой воркер и автопроверки — CSS-иллюстрации фич (это не отдельные экраны).

// Живой воркер (мокап 3). Строки лога терминала.
const workerLog = [
  { k: 'c', text: '// PF-219 · Собрать лендинг для запуска' },
  { k: 'p', text: '$ читаю ТЗ и структуру проекта' },
  { k: 'v', text: '→ создаю Hero, Features, Pricing' },
  { k: 'p', text: '$ пишу код компонентов' },
  { k: 'v', text: '→ верстаю адаптив, подключаю токены' },
  { k: 'p', text: '$ прогоняю сборку и линтер' },
];

// Автоулучшения (мокап 4). Чек-лист проверок перед выкаткой.
const checks = [
  { label: 'Сборка проходит без ошибок', done: true },
  { label: 'Линтер и типы — чисто', done: true },
  { label: 'Секреты не попали в код', done: true },
  { label: 'Адаптив на телефоне', done: true },
];

// Примеры использования — реальные типы задач, которые бросают простым текстом.
const examples = [
  'Собери лендинг для запуска',
  'Добавь экран оплаты',
  'Сделай тёмную тему',
  'Подключи Telegram-бота',
  'Почини баг и выкати',
  'Автоматизируй рутину проекта',
];
---

<section id="product" class="pf-section shots">
  <div class="pf-container">
    <div class="shots__head" data-reveal>
      <div class="pf-stag">Внутри продукта</div>
      <h2 class="pf-h2">Как это выглядит в&nbsp;работе</h2>
      <p class="pf-lead">
        Доска задач, живой прогресс воркера, прибыль с тратами и автопроверки перед
        выкаткой — настоящий интерфейс, а не картинки-заглушки.
      </p>
    </div>

    <!-- Мокап 1 · Реальный скриншот доски задач (снят с прод-приложения) + плавающие
         UI-фрагменты поверх — «разные экраны на одном», объём как у Notion. -->
    <figure class="shots__hero" data-reveal style="--tone-bg: #fdefda">
      <div class="shots__frame">
        <img
          src="/shots/app-board.png"
          alt="Скриншот доски задач ProjectsFlow: колонки Черновики, Вручную, Воркер (Claude Opus), Готово"
          width="1680"
          height="950"
          loading="lazy"
          decoding="async"
        />
      </div>

      <div class="shots__float shots__float--done" aria-hidden="true">
        <span class="shots__float-ic shots__float-ic--ok">
          <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg>
        </span>
        <span class="shots__float-txt"><b>Готово</b><span>PF-214 · лендинг собран</span></span>
      </div>

      <div class="shots__float shots__float--worker" aria-hidden="true">
        <span class="shots__float-ic shots__float-ic--ai">
          <svg viewBox="0 0 24 24" fill="#fff"><path d="M12 2.6l1.7 5.4h5.6l-4.5 3.3 1.7 5.4-4.5-3.3-4.5 3.3 1.7-5.4-4.5-3.3h5.6z" /></svg>
        </span>
        <span class="shots__float-txt"><b>Claude Opus</b><span>взял задачу в работу</span></span>
      </div>

      <!-- Второй экран поверх первого: мини-окно «Финансы» — интерфейс и функции разом. -->
      <div class="shots__mini shots__mini--finance" aria-hidden="true">
        <div class="shots__mini-bar">
          <span class="shots__mini-dot"></span>
          <span class="shots__mini-dot"></span>
          <span class="shots__mini-dot"></span>
          <em class="shots__mini-title">Финансы проекта</em>
        </div>
        <img src="/shots/app-finance.png" alt="" width="1680" height="950" loading="lazy" decoding="async" />
      </div>

      <figcaption class="shots__cap">
        <span class="shots__cap-label">Доска проекта.</span> Бросаешь идею — AI берёт её
        в работу и на глазах доводит до «Готово».
      </figcaption>
    </figure>

    <!-- Мокап 2 · Финансы простым языком (текст слева, окно справа). -->
    <div class="shots__split" data-reveal style="--tone-bg: #e9f1fc">
      <div class="shots__copy">
        <div class="pf-eyebrow">Деньги</div>
        <h3 class="shots__h3">Прибыль и траты — с одного взгляда</h3>
        <p class="shots__text">
          Никаких таблиц-простыней. Одна честная строка: сколько заработал, сколько
          потратил и в плюсе ли ты по проекту.
        </p>
      </div>
      <figure class="shots__fig shots__fig--tilt">
        <div class="shots__frame">
          <img
            src="/shots/app-finance.png"
            alt="Скриншот финансов проекта: доход 214 000 ₽, расход 85 600 ₽, прибыль 128 400 ₽"
            width="1680"
            height="950"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="shots__float shots__float--income" aria-hidden="true">
          <span class="shots__float-cap">Прибыль за месяц</span>
          <span class="shots__float-row">
            <span class="shots__float-val">+128 400 ₽</span>
            <svg class="shots__float-spark" viewBox="0 0 60 22" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M2 18 14 12 24 15 36 6 48 9 58 3" /></svg>
          </span>
        </div>

        <!-- Второй экран поверх: мини-окно «Доска» — видно, что финансы и задачи рядом. -->
        <div class="shots__mini shots__mini--board" aria-hidden="true">
          <div class="shots__mini-bar">
            <span class="shots__mini-dot"></span>
            <span class="shots__mini-dot"></span>
            <span class="shots__mini-dot"></span>
            <em class="shots__mini-title">Доска задач</em>
          </div>
          <img src="/shots/app-board.png" alt="" width="1680" height="950" loading="lazy" decoding="async" />
        </div>
      </figure>
    </div>

    <!-- Мокап 3 · Живой воркер (окно слева, текст справа) — локально тёмное окно. -->
    <div class="shots__split shots__split--rev" data-reveal style="--tone-bg: #efe9fd">
      <figure class="shots__fig">
        <div class="mock mock--lift" data-theme="dark">
          <div class="mock__chrome">
            <span class="mock__dot mock__dot--r"></span>
            <span class="mock__dot mock__dot--y"></span>
            <span class="mock__dot mock__dot--g"></span>
            <span class="mock__crumb mock__crumb--mono">worker · PF-219</span>
          </div>
          <div class="mock__body term" role="img" aria-label="Живой лог AI-воркера">
            <div class="term__log">
              {
                workerLog.map((line) => (
                  <span class:list={['term__line', `term__line--${line.k}`]}>{line.text}</span>
                ))
              }
              <span class="term__line term__line--live">
                <span class="term__caret" aria-hidden="true"></span> собираю production-бандл…
              </span>
            </div>
            <div class="term__foot">
              <div class="term__progress"><span style="width:84%"></span></div>
              <div class="term__meta">
                <span class="term__cost">84% · 3.20&nbsp;₽</span>
                <span class="term__status">В работе</span>
              </div>
            </div>
          </div>
        </div>
      </figure>
      <div class="shots__copy">
        <div class="pf-eyebrow">Прозрачность</div>
        <h3 class="shots__h3">Видно каждый шаг воркера</h3>
        <p class="shots__text">
          Живой лог: что AI делает прямо сейчас, на сколько процентов готово и во что
          обошлось — до копейки. Никакого чёрного ящика.
        </p>
      </div>
    </div>

    <!-- Мокап 4 · Автопроверки перед выкаткой (текст слева, окно справа). -->
    <div class="shots__split" data-reveal style="--tone-bg: #ddf2ea">
      <div class="shots__copy">
        <div class="pf-eyebrow">Безопасно</div>
        <h3 class="shots__h3">Проверки перед выкаткой</h3>
        <p class="shots__text">
          Прежде чем что-то попадёт в прод, платформа сама прогоняет сборку, линтер и
          проверку секретов. Зелёные галочки — значит можно катить.
        </p>
      </div>
      <figure class="shots__fig">
        <div class="mock mock--lift">
          <div class="mock__chrome">
            <span class="mock__dot mock__dot--r"></span>
            <span class="mock__dot mock__dot--y"></span>
            <span class="mock__dot mock__dot--g"></span>
            <span class="mock__crumb">PF-219 · Перед выкаткой</span>
          </div>
          <div class="mock__body checks" role="img" aria-label="Чек-лист автопроверок перед выкаткой">
            <div class="checks__head">
              <span class="checks__title">Автопроверки</span>
              <span class="checks__badge">4 из 4</span>
            </div>
            <ul class="checks__list">
              {
                checks.map((c) => (
                  <li class="checks__item">
                    <span class="checks__mark" aria-hidden="true">
                      <svg viewBox="0 0 16 16" width="14" height="14" fill="none">
                        <path d="M3.5 8.5l3 3 6-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                    </span>
                    <span class="checks__label">{c.label}</span>
                    <span class="checks__ok">ОК</span>
                  </li>
                ))
              }
            </ul>
            <div class="checks__foot">
              <span class="checks__ready">Готово к выкатке</span>
            </div>
          </div>
        </div>
      </figure>
    </div>

    <!-- Примеры использования: что можно поручить простым текстом. -->
    <div class="shots__examples" data-reveal>
      <div class="pf-stag shots__examples-tag">Примеры: что можно поручить</div>
      <div class="shots__examples-grid">
        {
          examples.map((e) => (
            <div class="shots__example">
              <span class="shots__example-q">«{e}»</span>
              <span class="shots__example-go">→ берём в работу</span>
            </div>
          ))
        }
      </div>
      <p class="shots__examples-note">
        Просто опиши задачу словами — остальное платформа берёт на себя.
      </p>
    </div>
  </div>
</section>

<style>
  .shots__head { max-width: 42rem; }

  /* --- Оконная рамка (браузер/аппка) ------------------------------------- */
  .mock {
    border: 1px solid var(--line);
    border-radius: var(--r-md);
    background: var(--surface);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }
  .mock--float { box-shadow: var(--shadow-float); }
  .mock--lift { box-shadow: var(--shadow-lg); }
  .mock__chrome {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    height: 40px;
    padding-inline: var(--sp-4);
    border-bottom: 1px solid var(--line);
    background: var(--surface-2);
  }
  .mock__dot { width: 11px; height: 11px; border-radius: 50%; flex: none; }
  .mock__dot--r { background: var(--danger); }
  .mock__dot--y { background: var(--warn); }
  .mock__dot--g { background: var(--signal); }
  .mock__crumb {
    margin-left: var(--sp-3);
    font-size: var(--fs-xs);
    color: var(--dim);
  }
  .mock__crumb--mono { font-family: var(--font-mono); }
  .mock__body { padding: var(--sp-5, 1.25rem); }

  /* Тёмное окно (только мокап живого воркера): все токены поверхностей/текста/линий
     флипаются глобальным правилом [data-theme='dark'] в tokens.css. Здесь — лишь мелкая
     подстройка глубины: инсеты (--surface-2) чуть темнее карточки для терминального дна. */
  .mock[data-theme='dark'] {
    --surface-2: var(--dark-bg);
  }

  /* --- Рамка реального скриншота (доска, финансы) — «парящий» вид как в Notion:
     мягкая многослойная тень со всех сторон + лёгкий hover-подъём. --------- */
  .shots__frame {
    position: relative;
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    overflow: hidden;
    background: var(--surface);
    box-shadow:
      0 1px 2px rgba(11, 18, 32, 0.05),
      0 8px 20px -6px rgba(11, 18, 32, 0.10),
      0 28px 50px -18px rgba(11, 18, 32, 0.18),
      0 60px 90px -40px rgba(11, 18, 32, 0.22);
    transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
  }
  /* Тонкий внутренний кант — «стекло» поверх скрина, добавляет объём. */
  .shots__frame::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.6), inset 0 0 0 1px rgba(11, 18, 32, 0.04);
    pointer-events: none;
  }
  .shots__frame img { display: block; width: 100%; height: auto; }
  @media (prefers-reduced-motion: no-preference) {
    .shots__frame:hover {
      transform: translateY(-6px);
      box-shadow:
        0 2px 4px rgba(11, 18, 32, 0.06),
        0 14px 30px -8px rgba(11, 18, 32, 0.12),
        0 40px 70px -24px rgba(11, 18, 32, 0.22),
        0 80px 120px -50px rgba(11, 18, 32, 0.28);
    }
  }

  /* --- Раскладка: скрин/мокап на цветной панели (как в Notion) ---------- */
  .shots__hero {
    position: relative;
    margin: var(--sp-12) 0 0;
    padding: clamp(1.25rem, 3vw, 2.5rem);
    border-radius: var(--r-lg);
    background: var(--tone-bg, transparent);
  }
  /* Лёгкий 3D-наклон большого скрина — объёмный вид как в Notion. */
  .shots__hero .shots__frame {
    transform: perspective(2600px) rotateX(4deg);
    transform-origin: center 78%;
  }
  @media (prefers-reduced-motion: no-preference) {
    .shots__hero .shots__frame:hover {
      transform: perspective(2600px) rotateX(2deg) translateY(-6px);
    }
  }

  /* Плавающие UI-фрагменты поверх скрина (композит «разные экраны»). */
  .shots__float {
    position: absolute;
    z-index: 3;
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    padding: 9px var(--sp-3);
    border-radius: var(--r);
    background: var(--surface);
    border: 1px solid rgba(11, 18, 32, 0.06);
    box-shadow:
      0 1px 2px rgba(11, 18, 32, 0.06),
      0 20px 40px -14px rgba(11, 18, 32, 0.30);
    pointer-events: none;
    white-space: nowrap;
  }
  .shots__float-txt { display: flex; flex-direction: column; line-height: 1.25; }
  .shots__float-txt b { font-size: var(--fs-sm); font-weight: 700; color: var(--text); }
  .shots__float-txt span { font-size: var(--fs-xs); color: var(--muted); }
  .shots__float-ic {
    flex: none;
    display: grid;
    place-items: center;
    width: 30px;
    height: 30px;
    border-radius: 50%;
  }
  .shots__float-ic svg { width: 16px; height: 16px; }
  .shots__float-ic--ok { background: linear-gradient(150deg, #43d6a0, #12a97b); }
  .shots__float-ic--ai { background: linear-gradient(150deg, #9b7bff, #6d4bf5); }

  .shots__float--done { top: 4%; right: 3%; --rot: 2.5deg; }
  .shots__float--worker { top: 40%; left: 2%; --rot: -2.5deg; }
  .shots__float--stat { bottom: 9%; right: 4%; --rot: 2deg; flex-direction: column; align-items: flex-start; gap: 3px; }
  .shots__float-cap { font-size: var(--fs-xs); color: var(--muted); }
  .shots__float-row { display: flex; align-items: center; gap: var(--sp-2); }
  .shots__float-val { font-size: var(--fs-base); font-weight: 800; color: #12a97b; letter-spacing: -0.01em; }
  .shots__float-spark { width: 54px; height: 20px; color: #12a97b; }

  /* Мини-окно второго экрана поверх основного скрина (наложение экранов, как у Notion). */
  .shots__mini {
    position: absolute;
    z-index: 3;
    overflow: hidden;
    border-radius: var(--r);
    background: var(--surface);
    border: 1px solid rgba(11, 18, 32, 0.10);
    box-shadow:
      0 2px 6px rgba(11, 18, 32, 0.10),
      0 34px 66px -22px rgba(11, 18, 32, 0.45);
    transform: rotate(var(--rot, 0deg));
  }
  .shots__mini-bar {
    display: flex;
    align-items: center;
    gap: 5px;
    height: 24px;
    padding: 0 10px;
    background: var(--surface-2);
    border-bottom: 1px solid var(--line);
  }
  .shots__mini-dot { flex: none; width: 7px; height: 7px; border-radius: 50%; background: rgba(11, 18, 32, 0.18); }
  .shots__mini-title { margin-left: 6px; font-style: normal; font-size: 10px; font-weight: 600; color: var(--muted); }
  .shots__mini img { display: block; width: 100%; height: auto; }
  .shots__mini--finance { width: 42%; right: 4%; bottom: 7%; --rot: -3deg; }
  .shots__mini--board { width: 46%; left: -0.5rem; bottom: -0.8rem; --rot: -3deg; }
  @media (max-width: 720px) { .shots__mini { display: none; } }

  .shots__float { transform: rotate(var(--rot, 0deg)); }
  @media (prefers-reduced-motion: no-preference) {
    .shots__float { animation: shots-float 6s var(--fd, 0s) ease-in-out infinite; }
    .shots__float--worker { --fd: -2s; }
    .shots__float--stat { --fd: -4s; }
    @keyframes shots-float {
      0%, 100% { transform: translateY(0) rotate(var(--rot, 0deg)); }
      50% { transform: translateY(-8px) rotate(calc(var(--rot, 0deg) * 0.4)); }
    }
  }
  /* На узких экранах прячем плавашки — негде размещать без наложения на текст. */
  @media (max-width: 720px) {
    .shots__float { display: none; }
  }
  .shots__cap {
    margin-top: var(--sp-3);
    font-size: var(--fs-sm);
    color: var(--muted);
    line-height: var(--lh-snug);
    max-width: 44rem;
  }
  .shots__cap-label { color: var(--text); font-weight: 600; }

  .shots__split {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-6);
    align-items: center;
    margin-top: var(--sp-8);
    padding: clamp(1.5rem, 3vw, 2.75rem);
    border-radius: var(--r-lg);
    background: var(--tone-bg, transparent);
  }
  @media (min-width: 900px) {
    .shots__split { grid-template-columns: 0.85fr 1.15fr; gap: var(--sp-12); }
    .shots__split--rev .shots__copy { order: 2; }
    .shots__split--rev .shots__fig { order: 1; }
  }
  .shots__copy { max-width: 30rem; }
  .shots__h3 {
    margin: var(--sp-3) 0 0;
    font-size: var(--fs-2xl);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    color: var(--text);
    line-height: var(--lh-tight);
  }
  .shots__text {
    margin: var(--sp-4) 0 0;
    font-size: var(--fs-base);
    color: var(--muted);
    line-height: var(--lh-normal);
  }
  .shots__fig { margin: 0; position: relative; }
  /* Лёгкий боковой 3D-угол для скрина финансов + плавающая карточка прибыли. */
  .shots__fig--tilt .shots__frame { transform: perspective(2200px) rotateY(-6deg); transform-origin: right center; }
  @media (prefers-reduced-motion: no-preference) {
    .shots__fig--tilt .shots__frame:hover { transform: perspective(2200px) rotateY(-3deg) translateY(-6px); }
  }
  .shots__float--income {
    top: -0.8rem;
    left: -0.8rem;
    --rot: -2deg;
    flex-direction: column;
    align-items: flex-start;
    gap: 3px;
  }


  /* --- Живой воркер: терминал (мокап 3, локально тёмный) ----------------- */
  .term { display: flex; flex-direction: column; gap: var(--sp-4); }
  .term__log {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 12.5px;
    line-height: 1.6;
  }
  .term__line { color: var(--muted); white-space: pre-wrap; word-break: break-word; }
  .term__line--c { color: var(--dim); }
  .term__line--p { color: var(--signal); }
  .term__line--v { color: var(--accent-bright); }
  .term__line--live {
    color: var(--text);
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }
  .term__caret {
    width: 7px;
    height: 13px;
    border-radius: 1px;
    background: var(--accent-bright);
    box-shadow: 0 0 10px var(--accent-bright);
    flex: none;
  }
  @media (prefers-reduced-motion: no-preference) {
    .term__caret { animation: pf-caret-blink 1.1s steps(1) infinite; }
  }
  @keyframes pf-caret-blink {
    0%, 50% { opacity: 1; }
    50.01%, 100% { opacity: 0.15; }
  }
  .term__foot { display: flex; flex-direction: column; gap: var(--sp-2); }
  .term__progress {
    height: 6px;
    border-radius: var(--r-full);
    background: var(--surface-2);
    overflow: hidden;
  }
  .term__progress span { display: block; height: 100%; background: var(--grad-accent); }
  .term__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
  }
  .term__cost { color: var(--accent-bright); font-weight: 600; }
  .term__status {
    color: var(--warn);
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }
  .term__status::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--warn);
  }

  /* --- Автопроверки (мокап 4) -------------------------------------------- */
  .checks { display: flex; flex-direction: column; gap: var(--sp-3); }
  .checks__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .checks__title { font-size: var(--fs-base); font-weight: 700; color: var(--text); }
  .checks__badge {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    font-weight: 600;
    color: var(--signal);
    background: var(--surface-2);
    border: 1px solid var(--line);
    border-radius: var(--r-full);
    padding: 2px 10px;
  }
  .checks__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--sp-2); }
  .checks__item {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-3);
    border: 1px solid var(--line);
    border-radius: var(--r-sm);
    background: var(--surface-2);
  }
  .checks__mark {
    flex: none;
    width: 22px;
    height: 22px;
    border-radius: var(--r-full);
    display: grid;
    place-items: center;
    color: var(--surface);
    background: var(--signal);
  }
  .checks__label { flex: 1; font-size: var(--fs-sm); color: var(--text); }
  .checks__ok {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    color: var(--signal);
  }
  .checks__foot {
    display: flex;
    align-items: center;
    padding-top: var(--sp-1);
  }
  .checks__ready {
    font-size: var(--fs-sm);
    font-weight: 600;
    color: var(--signal);
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }
  .checks__ready::before {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--signal);
    box-shadow: 0 0 8px var(--signal);
  }

  /* --- Примеры использования --------------------------------------------- */
  .shots__examples { margin-top: var(--sp-24); text-align: center; }
  .shots__examples-tag { display: block; }
  .shots__examples-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-3);
    margin-top: var(--sp-6);
  }
  @media (min-width: 640px) {
    .shots__examples-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .shots__examples-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .shots__example {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    padding: var(--sp-4);
    border: 1px solid var(--line);
    border-radius: var(--r);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
    text-align: left;
    transition: border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
  }
  @media (prefers-reduced-motion: no-preference) {
    .shots__example:hover { border-color: var(--accent-line); box-shadow: var(--shadow); }
  }
  .shots__example-q { font-size: var(--fs-base); font-weight: 600; color: var(--text); }
  .shots__example-go { font-size: var(--fs-xs); color: var(--accent); }
  .shots__examples-note {
    margin-top: var(--sp-6);
    font-size: var(--fs-sm);
    color: var(--muted);
  }

  /* --- Оживление: прогресс-бар воркера + чек-лист (reduced-motion-safe) --- */
  .term__progress span { position: relative; overflow: hidden; transition: width 0.8s ease; }
  @media (prefers-reduced-motion: no-preference) {
    /* Блик бежит по прогресс-бару — «идёт сборка». */
    .term__progress span::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.55), transparent);
      transform: translateX(-100%);
      animation: term-shimmer 1.9s ease-in-out infinite;
    }
    @keyframes term-shimmer {
      0% { transform: translateX(-100%); }
      55%, 100% { transform: translateX(320%); }
    }

    /* Чек-лист: галочки «прожимаются» по очереди. */
    .checks__mark { animation: checks-pop 4.5s ease-in-out infinite; }
    .checks__item:nth-child(2) .checks__mark { animation-delay: 0.4s; }
    .checks__item:nth-child(3) .checks__mark { animation-delay: 0.8s; }
    .checks__item:nth-child(4) .checks__mark { animation-delay: 1.2s; }
    @keyframes checks-pop {
      0%, 82%, 100% { transform: scale(1); }
      88% { transform: scale(1.22); }
    }

    /* Точка «Готово к выкатке» — пульс. */
    .checks__ready::before { animation: ready-pulse 2s ease-in-out infinite; }
    @keyframes ready-pulse {
      0%, 100% { opacity: 1; box-shadow: 0 0 8px var(--signal); }
      50% { opacity: 0.6; box-shadow: 0 0 2px var(--signal); }
    }
  }
</style>

<script>
  // «Живой» воркер-терминал: процент и стоимость ползут, прогресс плавно догоняет,
  // на 98% — «новый прогон». Уважает prefers-reduced-motion.
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const bar = document.querySelector<HTMLElement>('.term__progress span');
    const cost = document.querySelector<HTMLElement>('.term__cost');
    if (bar && cost) {
      let pct = 84;
      const tick = (): void => {
        pct += Math.random() < 0.75 ? 1 : 0;
        if (pct >= 98) pct = 71;
        bar.style.width = `${pct}%`;
        cost.textContent = `${pct}% · ${(pct * 0.038).toFixed(2)} ₽`;
      };
      setInterval(tick, 950);
    }
  }
</script>
