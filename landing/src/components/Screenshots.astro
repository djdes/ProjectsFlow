<script>
  // «Живой» воркер-терминал: процент и стоимость ползут, прогресс догоняет, на 98% —
  // новый прогон. Уважает prefers-reduced-motion.
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const bar = document.querySelector<HTMLElement>('.term__progress span');
    const cost = document.querySelector<HTMLElement>('.term__cost');
    if (bar && cost) {
      let pct = 84;
      setInterval(() => {
        pct += Math.random() < 0.75 ? 1 : 0;
        if (pct >= 98) pct = 71;
        bar.style.width = `${pct}%`;
        cost.textContent = `${pct}% · ${(pct * 0.038).toFixed(2)} ₽`;
      }, 950);
    }
  }
</script>
