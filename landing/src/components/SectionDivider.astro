---
// Тихий шов между секциями: тонкая линия, растворяющаяся к краям, с едва заметной
// точкой-акцентом по центру. Никакого неона/бесконечных анимаций — в духе editorial paper.
---

<div class="section-divider" aria-hidden="true">
  <span class="section-divider__line"></span>
  <span class="section-divider__tick"></span>
</div>

<style>
  .section-divider {
    position: relative;
    height: clamp(1.5rem, 3vw, 2.5rem);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg);
  }
  .section-divider__line {
    position: absolute;
    inset-inline: 12%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--line), transparent);
  }
  .section-divider__tick {
    position: relative;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.5;
  }
</style>
