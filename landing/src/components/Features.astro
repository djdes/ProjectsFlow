---
import { FEATURES, EXTRA_FEATURES } from '@/data/features';

// Line-иконки (24×24) под ключи из features.ts. Циан-плитка задаётся в стилях.
const ICONS: Record<string, string> = {
  // идея / лампочка
  idea: 'M9 18h6M10 21h4M12 3a6 6 0 00-3.8 10.6c.7.6 1.3 1.2 1.3 2.4h5c0-1.2.6-1.8 1.3-2.4A6 6 0 0012 3z',
  // автопилот / бесконечность
  autopilot:
    'M7 8.5a3.5 3.5 0 100 7c1.7 0 2.8-1.2 4-2.5l1-1.1c1.2-1.3 2.3-2.4 4-2.4a3.5 3.5 0 110 7c-1.7 0-2.8-1.2-4-2.4l-1-1.2c-1.2-1.3-2.3-2.5-4-2.5z',
  // рубль / стоимость
  cost: 'M9 5h4.5a3.5 3.5 0 010 7H9m0 0V5m0 7v7m0-7H7m2 4H7',
  // «всё в одной коробке» — куб
  allin: 'M12 3l8 4.5v9L12 21l-8-4.5v-9L12 3zM12 3v18M4 7.5l8 4.5 8-4.5',
};
---

<section id="features" class="pf-section features">
  <div class="features__blob mesh-blob" aria-hidden="true"></div>

  <div class="pf-container">
    <div class="features__head" data-reveal>
      <div class="pf-stag">Возможности</div>
      <h2 class="pf-h2">Меньше рутины — больше готового</h2>
      <p class="pf-lead">
        Идеи, работа над ними и деньги — в одном месте. Ты задаёшь направление, платформа
        доводит до результата. Без разброса по чатам и десятку вкладок.
      </p>
    </div>

    <div class="features__grid">
      {
        FEATURES.map((f, i) => (
          <article
            class="pf-card pf-card--hover features__card"
            data-reveal
            style={`--reveal-delay: ${i * 80}ms`}
          >
            <div class="features__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                <path d={ICONS[f.icon]} stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <h3 class="features__title">{f.title}</h3>
            <p class="features__body">{f.body}</p>
            <span class="pf-underline" aria-hidden="true"></span>
          </article>
        ))
      }
    </div>

    <ul class="features__extra" data-reveal aria-label="Дополнительные возможности">
      {
        EXTRA_FEATURES.map((x) => (
          <li class="features__chip">
            <span class="features__chip-dot" aria-hidden="true"></span>
            {x}
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .features { overflow: hidden; }
  .features__blob {
    width: 560px;
    height: 560px;
    background: var(--accent-deep);
    top: -10%;
    right: -18%;
    opacity: 0.14;
  }
  .features__head { max-width: 40rem; }

  .features__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-4);
    margin-top: var(--sp-12);
  }
  @media (min-width: 640px) {
    .features__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .features__grid { grid-template-columns: repeat(4, 1fr); }
  }

  .features__card {
    overflow: hidden;
    padding: var(--sp-6);
  }
  .features__icon {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: var(--r-sm);
    color: var(--accent);
    background: var(--accent-soft);
    border: 1px solid var(--accent-line);
  }
  .features__icon svg { width: 22px; height: 22px; }
  .features__title {
    margin-top: var(--sp-4);
    font-size: var(--fs-lg);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    color: var(--text);
  }
  .features__body {
    margin-top: var(--sp-2);
    font-size: var(--fs-sm);
    line-height: var(--lh-normal);
    color: var(--muted);
  }
  .features__tag {
    display: inline-block;
    margin-top: var(--sp-4);
    font-size: var(--fs-xs);
    color: var(--dim);
    padding: 2px 8px;
    border: 1px solid var(--line);
    border-radius: var(--r-sm);
  }

  .features__extra {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2) var(--sp-6);
    justify-content: center;
    margin-top: var(--sp-12);
    padding: 0;
  }
  .features__chip {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-sm);
    color: var(--muted);
  }
  .features__chip-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.7;
  }
</style>
