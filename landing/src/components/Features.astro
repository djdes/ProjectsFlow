---
const features = [
  {
    title: 'База знаний',
    body:
      'Markdown-доки в твоём GitHub-репозитории. Frontmatter валидируется, ссылки на секреты не ломаются. Чужой репозиторий — твоя структура.',
    iconPath:
      'M4 6.5a2.5 2.5 0 012.5-2.5H17a1 1 0 011 1v13a1 1 0 01-1 1H6.5A2.5 2.5 0 014 16.5v-10zM7 8h7M7 12h5',
  },
  {
    title: 'Хранилище секретов',
    body:
      'AES-256-GCM на сервере. Ключи API, пароли БД, токены — без leak в gist и без копипасты в Telegram.',
    iconPath:
      'M12 11v2.5M7 11V7a5 5 0 0110 0v4M5 11h14a1 1 0 011 1v7a1 1 0 01-1 1H5a1 1 0 01-1-1v-7a1 1 0 011-1z',
  },
  {
    title: 'GitHub-интеграция',
    body:
      'Device Flow без OAuth-приключений. Видишь коммиты по проекту в одном месте, привязываешь их к задачам.',
    iconPath:
      'M12 2a10 10 0 00-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.46-1.16-1.12-1.47-1.12-1.47-.92-.62.07-.61.07-.61 1.01.07 1.55 1.04 1.55 1.04.9 1.54 2.36 1.1 2.94.84.09-.65.35-1.1.64-1.35-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.26-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02a9.6 9.6 0 015 0c1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.39.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.93.36.31.68.92.68 1.85v2.74c0 .27.18.58.69.48A10 10 0 0012 2z',
  },
  {
    title: 'Доска задач',
    body:
      'Лёгкий канбан с привязкой задач к коммитам. Без Jira-обвеса и без полей, в которые никто не пишет.',
    iconPath:
      'M5 5h4v14H5zM10 5h4v9h-4zM15 5h4v6h-4z',
  },
];
---

<section id="features" class="relative py-28">
  <div
    class="mesh-blob"
    style="width: 600px; height: 600px; background: #1e3a8a; top: 10%; right: -15%; opacity: 0.18;"
  >
  </div>

  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <span class="eyebrow">Возможности</span>
      <h2 class="mt-5 text-balance text-3xl font-semibold tracking-tight text-ink-50 sm:text-5xl">
        Всё, что нужно знать о&nbsp;проекте — в&nbsp;одном месте
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-balance text-base leading-relaxed text-ink-200">
        Не таск-трекер. Не DevOps-панель. Живое досье, в которое возвращаешься через полгода
        и сразу понимаешь, что и как работает.
      </p>
    </div>

    <div class="mt-16 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        features.map((f) => (
          <article class="glass group relative overflow-hidden rounded-2xl p-6 transition-transform hover:-translate-y-1">
            <div
              class="grid size-11 place-items-center rounded-xl bg-gradient-to-br from-accent-400/20 to-accent-600/10 text-accent-400 ring-1 ring-inset ring-accent-400/15"
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="size-5">
                <path d={f.iconPath} stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <h3 class="mt-5 text-lg font-semibold tracking-tight text-ink-50">{f.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-200">{f.body}</p>

            <div
              class="pointer-events-none absolute inset-x-0 -bottom-px h-px bg-gradient-to-r from-transparent via-accent-400/40 to-transparent opacity-0 transition-opacity group-hover:opacity-100"
            />
          </article>
        ))
      }
    </div>
  </div>
</section>
