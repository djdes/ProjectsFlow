---
import KanbanBoard from './KanbanBoard.tsx';
import Floaties from './Floaties.astro';

// Лендинг и SPA — один Express в prod, пути относительные.
const appBase = (import.meta.env.PUBLIC_APP_URL ?? '').replace(/\/+$/, '');

// Три ключевых пункта вместо описательного абзаца (по брифу владельца).
const points = [
  {
    key: 'llm',
    title: 'Подписка на Claude — уже внутри',
    text: 'Онлайн-доступ к ведущим LLM. Без VPN и без своих API-ключей — просто работаешь.',
  },
  {
    key: 'money',
    title: 'Прибыль и траты — понятным языком',
    text: 'Видно, сколько проект заработал и сколько потратил. Без таблиц и лишних терминов.',
  },
  {
    key: 'auto',
    title: 'Автоматизации из коробки',
    text: 'Автоулучшения, проверки безопасности и доска, где задачи выполняет AI-воркер.',
  },
];
---

<section class="hero" aria-labelledby="hero-title">
  <!-- Тихий ambient-слой: лёгкая координатная сетка + один мягкий цианный свет. -->
  <div class="hero__bg" aria-hidden="true">
    <div class="hero__grid grid-bg"></div>
    <div class="mesh-blob mesh-blob--magnetic hero__glow" data-magnetic-blob></div>
    <Floaties count={13} opacity={0.42} />
  </div>

  <div class="hero__wide hero__inner">
    <div class="hero__col">
      <h1 id="hero-title" class="hero__title">
        Опиши идею — получи <span class="pf-grad">готовый продукт</span>.
      </h1>

      <ul class="hero__points">
        {
          points.map((p) => (
            <li class="hero__point" data-reveal>
              <span class="hero__point-ic" aria-hidden="true">
                {p.key === 'llm' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
                    <path d="M13 3 4 14h7l-1 7 9-11h-7l1-7Z" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                )}
                {p.key === 'money' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
                    <path d="M4 19V9m5 10V5m5 14v-6m5 6V8" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                )}
                {p.key === 'auto' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
                    <circle cx="12" cy="12" r="3.2" />
                    <path
                      d="M12 3v2.5M12 18.5V21M3 12h2.5M18.5 12H21M5.6 5.6l1.8 1.8M16.6 16.6l1.8 1.8M18.4 5.6l-1.8 1.8M7.4 16.6l-1.8 1.8"
                      stroke-linecap="round"
                    />
                  </svg>
                )}
              </span>
              <span class="hero__point-body">
                <span class="hero__point-title">{p.title}</span>
                <span class="hero__point-text">{p.text}</span>
              </span>
            </li>
          ))
        }
      </ul>

      <!-- Оффер + быстрый старт (email → регистрация). Анимированная приглашающая кнопка. -->
      <div class="hero__start" data-reveal style="--reveal-delay: 120ms">
        <p class="hero__offer">
          <span class="hero__offer-badge">1 час бесплатно</span>
          <span class="hero__offer-text">Первый час на <b>Прайме</b> — без карты. Первый результат — в первый час.</span>
        </p>

        <form class="hero__form" data-auth-anon data-hero-start data-app-base={appBase}>
          <input
            type="email"
            name="email"
            class="hero__email"
            placeholder="Твой e-mail"
            autocomplete="email"
            aria-label="E-mail для старта"
          />
          <button type="submit" class="pf-btn pf-btn--primary pf-btn--lg pf-btn--invite">
            Начать бесплатно
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" class="hero__arrow" aria-hidden="true">
              <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </button>
        </form>
        <a href={`${appBase}/login`} data-auth-anon class="hero__login">Уже есть аккаунт? Войти</a>

        <!-- Authed (скрыто изначально; BaseLayout выставит data-auth="authed"). -->
        <a
          href={`${appBase}/`}
          data-auth-authed
          class="pf-btn pf-btn--primary pf-btn--lg pf-btn--invite hero__authed"
        >
          Открыть приложение
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" class="hero__arrow" aria-hidden="true">
            <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </a>

        <div class="hero__promises" data-reveal style="--reveal-delay: 200ms">
          <span class="hero__promise">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M4 10.5l4 4 8-9" stroke-linecap="round" stroke-linejoin="round" /></svg>
            Старт без карты
          </span>
          <span class="hero__promise hero__promise--key">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M12 2.5l7 3v5.5c0 5-3.2 8.6-7 10.5-3.8-1.9-7-5.5-7-10.5V5.5l7-3z" stroke-linecap="round" stroke-linejoin="round" /><path d="M9 12l2 2 4-4.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
            Не&nbsp;зашло — вернём деньги
          </span>
          <span class="hero__promise">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M4 10.5l4 4 8-9" stroke-linecap="round" stroke-linejoin="round" /></svg>
            Проект остаётся твоим
          </span>
        </div>
      </div>
    </div>

    <!-- Правая колонка: ЕДИНСТВЕННАЯ на лендинге интерактивная доска. Перетащи задачу на
         «Воркер» — AI берёт её в работу. Остальные доски со страницы убраны. -->
    <div class="hero__showcase" data-reveal style="--reveal-delay: 200ms">
      <KanbanBoard client:visible />
      <p class="hero__showcase-cap">
        Перетащи задачу на <b>«Воркер»</b> — или просто нажми. AI возьмёт её в работу.
      </p>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    display: flex;
    align-items: center;
    padding-block: clamp(3rem, 7vw, 6rem);
  }

  /* --- Тихий ambient --- */
  .hero__bg { position: absolute; inset: 0; z-index: -20; pointer-events: none; }
  .hero__grid { position: absolute; inset: 0; }
  .hero__glow {
    width: 620px; height: 620px;
    background: var(--accent);
    top: -260px; right: -120px;
    opacity: 0.12;
  }

  /* --- Раскладка --- */
  .hero__wide {
    width: 100%;
    max-width: var(--container-wide);
    margin-inline: auto;
    padding-inline: clamp(1rem, 4vw, 2rem);
  }
  .hero__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--sp-12);
  }
  .hero__col { width: 100%; max-width: 620px; }

  .hero__title {
    font-size: var(--fs-display);
    line-height: var(--lh-tight);
    letter-spacing: var(--tracking-tight);
    font-weight: 720;
    color: var(--text);
    text-wrap: balance;
  }

  /* --- 3 ключевых пункта --- */
  .hero__points {
    list-style: none;
    margin: var(--sp-8) 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    max-width: 34rem;
  }
  .hero__point { display: flex; gap: var(--sp-3); align-items: flex-start; }
  .hero__point-ic {
    flex: none;
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: var(--r-sm);
    border: 1px solid var(--accent-line);
    background: var(--accent-soft);
    color: var(--accent);
  }
  .hero__point-ic svg { width: 20px; height: 20px; }
  .hero__point-body { display: flex; flex-direction: column; gap: 2px; }
  .hero__point-title { font-size: var(--fs-base); font-weight: 650; color: var(--text); }
  .hero__point-text { font-size: var(--fs-sm); color: var(--muted); line-height: var(--lh-snug); }

  /* --- Оффер + старт --- */
  .hero__start { margin-top: var(--sp-8); max-width: 34rem; }
  .hero__offer {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-2) var(--sp-3);
    padding: var(--sp-3) var(--sp-4);
    border: 1px solid var(--accent-line);
    border-radius: var(--r);
    background: var(--accent-soft);
    font-size: var(--fs-sm);
    color: var(--text);
    line-height: var(--lh-snug);
  }
  .hero__offer b { color: var(--accent-deep); font-weight: 700; }
  .hero__offer-text { flex: 1 1 12rem; min-width: 0; }
  .hero__offer-badge {
    flex: none;
    padding: var(--sp-1) var(--sp-3);
    border-radius: var(--r-full);
    background: var(--grad-accent);
    color: var(--accent-ink);
    font-size: var(--fs-xs);
    font-weight: 800;
    white-space: nowrap;
  }

  .hero__form {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-top: var(--sp-4);
  }
  .hero__email {
    flex: 1 1 200px;
    min-width: 0;
    height: 50px;
    padding-inline: var(--sp-4);
    border-radius: var(--r-sm);
    border: 1px solid var(--line-strong);
    background: var(--surface);
    color: var(--text);
    font-size: var(--fs-base);
    font-family: inherit;
    transition: border-color var(--dur-fast) var(--ease), box-shadow var(--dur-fast) var(--ease);
  }
  .hero__email::placeholder { color: var(--dim); }
  .hero__email:focus-visible {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }
  .hero__authed { display: none; margin-top: var(--sp-4); }
  .hero__arrow { width: 16px; height: 16px; }
  .hero__login {
    display: inline-block;
    margin-top: var(--sp-3);
    font-size: var(--fs-sm);
    color: var(--muted);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color var(--dur-fast) var(--ease), border-color var(--dur-fast) var(--ease);
  }
  .hero__login:hover { color: var(--accent); border-color: var(--accent-line); }
  /* Снятие риска у самой кнопки (Хормози): три обещания, гарантия возврата — выделена. */
  .hero__promises {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-top: var(--sp-4);
  }
  .hero__promise {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 10px;
    border-radius: var(--r-full);
    border: 1px solid var(--line);
    background: var(--surface);
    font-size: var(--fs-sm);
    color: var(--muted);
  }
  .hero__promise svg { width: 14px; height: 14px; flex: none; color: var(--signal); }
  .hero__promise--key {
    border-color: var(--accent);
    background: var(--accent-soft);
    color: var(--accent-deep);
    font-weight: 700;
  }
  .hero__promise--key svg { color: var(--accent-deep); }

  /* --- Правая колонка --- */
  .hero__showcase { width: 100%; display: flex; flex-direction: column; align-items: center; gap: var(--sp-3); }
  .hero__showcase-cap { font-size: var(--fs-sm); color: var(--muted); text-align: center; max-width: 30rem; }
  .hero__showcase-cap b { color: var(--accent); font-weight: 700; }

  /* Десктоп: две колонки — текст + доска (пошире). */
  @media (min-width: 1040px) {
    .hero__inner {
      display: grid;
      grid-template-columns: minmax(0, 1.02fr) minmax(0, 0.98fr);
      gap: var(--sp-12);
      align-items: center;
    }
    .hero__col { max-width: 600px; }
    .hero__showcase { justify-self: end; }
  }
</style>

<script>
  // Лёгкий параллакс мягкого cyan-света за курсором. Уважает reduced-motion.
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduceMotion) {
    const blob = document.querySelector<HTMLElement>('[data-magnetic-blob]');
    if (blob) {
      const MAX = 50;
      window.addEventListener(
        'pointermove',
        (e: PointerEvent) => {
          const nx = (e.clientX / window.innerWidth) * 2 - 1;
          const ny = (e.clientY / window.innerHeight) * 2 - 1;
          blob.style.setProperty('--blob-x', `${nx * MAX}px`);
          blob.style.setProperty('--blob-y', `${ny * MAX}px`);
        },
        { passive: true },
      );
    }
  }
</script>

<script>
  // Быстрый старт: e-mail из героя → на регистрацию с предзаполнением. Без e-mail — просто регистрация.
  const form = document.querySelector<HTMLFormElement>('[data-hero-start]');
  if (form) {
    const base = (form.getAttribute('data-app-base') ?? '').replace(/\/+$/, '');
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const email = new FormData(form).get('email');
      const q = typeof email === 'string' && email.includes('@') ? `?email=${encodeURIComponent(email)}` : '';
      window.location.href = `${base}/register${q}`;
    });
  }
</script>
