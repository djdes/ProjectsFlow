---
import HeroSceneGate from './HeroSceneGate.tsx';

// Лендинг и SPA — один Express в prod, пути относительные.
const appBase = (import.meta.env.PUBLIC_APP_URL ?? '').replace(/\/+$/, '');

// Превью «проекта» в Hero — человеческие задачи и их статусы (без кода/терминала).
const previewTasks = [
  { label: 'Экран входа', state: 'done' as const, tag: 'Готово' },
  { label: 'Подключить оплату', state: 'done' as const, tag: 'Готово' },
  { label: 'Тёмная тема', state: 'doing' as const, tag: 'AI делает…' },
  { label: 'Рассылка к запуску', state: 'idea' as const, tag: 'Идея' },
];
---

<section class="hero" aria-labelledby="hero-title">
  <!-- Ambient-слой = статичный «постер»: координатная сетка + цианово-зелёные свечения.
       Виден всегда; на мобиле/при reduced-motion заменяет 3D-сцену. -->
  <div class="hero__bg" aria-hidden="true">
    <div class="hero__grid grid-bg"></div>
    <div class="mesh-blob mesh-blob--magnetic hero__glow-cyan" data-magnetic-blob></div>
    <div class="mesh-blob hero__glow-green"></div>
    <div class="hero__vignette"></div>
  </div>

  <!-- 3D-сцена: грузится только на десктопе с motion и WebGL (chunk не качается на мобиле). -->
  <div class="hero__scene" aria-hidden="true">
    <HeroSceneGate client:media="(min-width: 1024px)" />
  </div>

  <!-- Фоновые синие частицы, постоянно притягивающиеся к кнопке «Начать бесплатно».
       Только в Hero; плавно гаснут при скролле ниже. Не мешают кликам (pointer-events:none). -->
  <canvas class="hero__particles" data-particles aria-hidden="true"></canvas>

  <div class="pf-container hero__inner">
    <div class="hero__col">
      <span class="pf-eyebrow">
        <span class="pf-dot"></span>
        Для тех, кто строит с AI
      </span>

      <h1 id="hero-title" class="hero__title">
        Опиши идею — получи <span class="pf-grad">готовый продукт</span>.
      </h1>

      <p class="hero__sub">
        ProjectsFlow ведёт твой проект от задумки до запуска: ты говоришь, что хочешь, —
        платформа делает и доводит до результата. Без настройки и технической возни.
        Ты&nbsp;— на драйве идей.
      </p>

      <!-- Главный оффер: бесплатный час Прайма — ярко выделен. -->
      <div class="hero__offer" data-reveal>
        <span class="hero__offer-badge">1 час бесплатно</span>
        <span class="hero__offer-text">
          Первый час на <b>Прайме</b> — без карты. <b>Первый результат увидишь в первый час.</b>
        </span>
      </div>

      <div class="hero__cta">
        {/* Anonymous (по умолчанию). Скрипт в BaseLayout заменит на «Открыть приложение». */}
        <a href={`${appBase}/register`} data-auth-anon class="pf-btn pf-btn--primary pf-btn--lg">
          Начать бесплатно
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" class="hero__arrow" aria-hidden="true">
            <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </a>
        <a href={`${appBase}/login`} data-auth-anon class="pf-btn pf-btn--ghost pf-btn--lg">Войти</a>
        {/* Authed (скрыто изначально). */}
        <a href={`${appBase}/`} data-auth-authed class="pf-btn pf-btn--primary pf-btn--lg hero__authed">
          Открыть приложение
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" class="hero__arrow" aria-hidden="true">
            <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </a>
      </div>

      <p class="hero__reassure">Старт бесплатно и без карты · не зашло — вернём деньги · проект остаётся твоим</p>

      <!-- Превью проекта — задумки превращаются в готовое. Без кода/терминала. -->
      <div class="hero__panel" data-reveal style="--reveal-delay: 200ms">
        <div class="hero__panel-head">
          <span class="hero__panel-title">Мой проект</span>
          <span class="hero__panel-live">
            <span class="pf-dot"></span> AI на связи
          </span>
        </div>
        <ul class="hero__tasks">
          {
            previewTasks.map((t) => (
              <li class={`hero__task hero__task--${t.state}`}>
                <span class="hero__task-mark" aria-hidden="true">
                  {t.state === 'done' ? (
                    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.4">
                      <path d="M4 10.5l4 4 8-9" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  ) : t.state === 'doing' ? (
                    <span class="hero__spin"></span>
                  ) : (
                    <span class="hero__ring"></span>
                  )}
                </span>
                <span class="hero__task-label">{t.label}</span>
                <span class="hero__task-tag">{t.tag}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    min-height: calc(100dvh - 60px);
    display: flex;
    align-items: center;
  }

  /* --- Ambient «постер» --- */
  .hero__bg { position: absolute; inset: 0; z-index: -20; pointer-events: none; }
  .hero__grid { position: absolute; inset: 0; }
  .hero__glow-cyan {
    width: 560px; height: 560px; background: var(--accent-deep);
    top: -180px; left: 50%; margin-left: -280px; opacity: 0.4;
  }
  .hero__glow-green {
    width: 380px; height: 380px; background: #0e7a4d;
    top: 360px; right: -120px; opacity: 0.26;
  }
  .hero__vignette {
    position: absolute; inset-inline: 0; bottom: 0; height: 12rem;
    background: linear-gradient(to bottom, transparent, var(--bg));
  }

  /* --- 3D-сцена --- */
  .hero__scene {
    position: absolute; inset: 0; z-index: -10; pointer-events: none;
    -webkit-mask-image: linear-gradient(to bottom, #000 0%, #000 72%, transparent 100%);
    mask-image: linear-gradient(to bottom, #000 0%, #000 72%, transparent 100%);
  }

  /* --- Частицы (поверх сцены, под контентом; не ловят клики) --- */
  .hero__particles {
    position: absolute;
    inset: 0;
    z-index: -5;
    width: 100%;
    height: 100%;
    pointer-events: none;
    opacity: 0;
    transition: opacity 600ms var(--ease);
  }
  .hero__particles[data-active] { opacity: 1; }

  /* --- Контент --- */
  .hero__inner { position: relative; padding-block: clamp(2.5rem, 6vw, 4.5rem); }
  .hero__col { width: 100%; max-width: 640px; }
  .hero__title {
    margin-top: var(--sp-6);
    font-size: var(--fs-display);
    line-height: var(--lh-tight);
    letter-spacing: var(--tracking-tight);
    font-weight: 800;
    color: var(--text);
    text-wrap: balance;
  }
  .hero__sub {
    margin-top: var(--sp-6);
    max-width: 34rem;
    color: var(--muted);
    font-size: var(--fs-lg);
    line-height: var(--lh-normal);
  }
  /* --- Оффер «1 час бесплатно» — яркий акцент --- */
  .hero__offer {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    margin-top: var(--sp-6);
    max-width: 34rem;
    padding: var(--sp-3) var(--sp-4);
    border: 1px solid var(--accent-line);
    border-radius: var(--r);
    background:
      radial-gradient(120% 160% at 0% 50%, var(--accent-soft), transparent 70%),
      rgba(255, 255, 255, 0.02);
    box-shadow: 0 0 0 1px var(--accent-line), var(--glow);
  }
  .hero__offer-badge {
    flex: none;
    padding: var(--sp-1) var(--sp-3);
    border-radius: var(--r-full);
    background: var(--grad-accent);
    color: var(--accent-ink);
    font-size: var(--fs-xs);
    font-weight: 800;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }
  .hero__offer-text { font-size: var(--fs-sm); color: var(--text); line-height: var(--lh-snug); }
  .hero__offer-text b { color: var(--accent); font-weight: 700; }

  .hero__cta { display: flex; flex-wrap: wrap; gap: var(--sp-3); margin-top: var(--sp-6); }
  .hero__authed { display: none; }
  .hero__arrow { width: 16px; height: 16px; }
  .hero__reassure {
    margin-top: var(--sp-4);
    font-size: var(--fs-sm);
    color: var(--dim);
  }

  /* --- Превью проекта --- */
  .hero__panel {
    margin-top: var(--sp-12);
    max-width: 460px;
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    background: linear-gradient(180deg, var(--surface), #080b11);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }
  .hero__panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--sp-3) var(--sp-4);
    border-bottom: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.02);
  }
  .hero__panel-title { font-size: var(--fs-sm); font-weight: 600; color: var(--text); }
  .hero__panel-live {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-xs);
    color: var(--signal);
  }
  .hero__tasks { list-style: none; margin: 0; padding: var(--sp-2); display: flex; flex-direction: column; gap: 2px; }
  .hero__task {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-3);
    border-radius: var(--r-sm);
    transition: background-color var(--dur) var(--ease);
  }
  .hero__task--doing {
    background: var(--accent-soft);
    box-shadow: inset 0 0 0 1px var(--accent-line);
  }
  .hero__task-mark {
    flex: none;
    display: grid;
    place-items: center;
    width: 22px;
    height: 22px;
  }
  .hero__task--done .hero__task-mark { color: var(--signal); }
  .hero__task--done .hero__task-mark svg { width: 16px; height: 16px; }
  .hero__ring {
    width: 13px; height: 13px; border-radius: 50%;
    border: 1.6px solid var(--dim);
  }
  .hero__spin {
    width: 15px; height: 15px; border-radius: 50%;
    border: 2px solid var(--accent-line);
    border-top-color: var(--accent);
  }
  @media (prefers-reduced-motion: no-preference) {
    .hero__spin { animation: hero-spin 0.9s linear infinite; }
    @keyframes hero-spin { to { transform: rotate(360deg); } }
  }
  .hero__task-label { flex: 1; min-width: 0; font-size: var(--fs-sm); color: var(--text); }
  .hero__task--idea .hero__task-label { color: var(--muted); }
  .hero__task-tag {
    flex: none;
    font-size: var(--fs-xs);
    color: var(--dim);
  }
  .hero__task--doing .hero__task-tag { color: var(--accent); }
  .hero__task--done .hero__task-tag { color: var(--signal); }

  /* На десктопе текст занимает ~58% ширины — справа дышит 3D-сцена. */
  @media (min-width: 1024px) {
    .hero__col { max-width: 58%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__panel { opacity: 1; }
  }
</style>

<script>
  // Лёгкий параллакс cyan-свечения за курсором. Уважает reduced-motion.
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduceMotion) {
    const blob = document.querySelector<HTMLElement>('[data-magnetic-blob]');
    if (blob) {
      const MAX = 70;
      window.addEventListener(
        'pointermove',
        (e: PointerEvent) => {
          const nx = (e.clientX / window.innerWidth) * 2 - 1;
          const ny = (e.clientY / window.innerHeight) * 2 - 1;
          blob.style.setProperty('--blob-x', `${nx * MAX}px`);
          blob.style.setProperty('--blob-y', `${ny * MAX}px`);
        },
        { passive: true },
      );
    }
  }
</script>

<script>
  // Синие светящиеся частицы, постоянно «притягивающиеся» к кнопке «Начать бесплатно».
  // Фоновые (НЕ зависят от курсора), быстрые — создают эффект непрерывного притяжения к
  // кнопке. Только в Hero; плавно гаснут при скролле ниже. Отключены при reduced-motion.
  (() => {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) return;

    const hero = document.querySelector<HTMLElement>('.hero');
    const canvas = document.querySelector<HTMLCanvasElement>('[data-particles]');
    const target = hero?.querySelector<HTMLElement>('a.pf-btn--primary[data-auth-anon]');
    if (!hero || !canvas || !target) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    type P = { x: number; y: number; vx: number; vy: number; life: number; r: number };
    const parts: P[] = [];
    const TARGET = 64; // фоновая плотность частиц
    let W = 0;
    let H = 0;
    let tx = 0; // цель — центр кнопки, в координатах канваса
    let ty = 0;
    let active = false;
    let raf = 0;

    const measure = (): void => {
      const hr = hero.getBoundingClientRect();
      W = hr.width;
      H = hr.height;
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = Math.round(W * dpr);
      canvas.height = Math.round(H * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      const tr = target.getBoundingClientRect();
      tx = tr.left - hr.left + tr.width / 2;
      ty = tr.top - hr.top + tr.height / 2;
    };
    measure();
    window.addEventListener('resize', measure, { passive: true });

    // Фоновый спавн: частица появляется в случайной точке Hero и летит к кнопке.
    const spawnOne = (): void => {
      parts.push({
        x: Math.random() * W,
        y: Math.random() * H,
        vx: (Math.random() - 0.5) * 0.8,
        vy: (Math.random() - 0.5) * 0.8,
        life: 0.6 + Math.random() * 0.6,
        r: 1 + Math.random() * 2,
      });
    };

    const ACCEL = 0.5; // сильное притяжение → быстрое движение к кнопке
    const DRAG = 0.9;
    const MAXV = 8;

    const step = (): void => {
      ctx.clearRect(0, 0, W, H);
      ctx.globalCompositeOperation = 'lighter';
      // Поддерживаем фоновую плотность плавным дозированным спавном.
      if (active) {
        let add = 0;
        while (parts.length < TARGET && add < 3) {
          spawnOne();
          add++;
        }
      }
      for (let i = parts.length - 1; i >= 0; i--) {
        const p = parts[i]!;
        const dx = tx - p.x;
        const dy = ty - p.y;
        const dist = Math.hypot(dx, dy) || 1;
        p.vx += (dx / dist) * ACCEL;
        p.vy += (dy / dist) * ACCEL;
        p.vx *= DRAG;
        p.vy *= DRAG;
        const sp = Math.hypot(p.vx, p.vy);
        if (sp > MAXV) {
          p.vx = (p.vx / sp) * MAXV;
          p.vy = (p.vy / sp) * MAXV;
        }
        p.x += p.vx;
        p.y += p.vy;
        p.life -= 0.006;
        if (dist < 18) p.life -= 0.16; // у кнопки гаснет и переродится в другом месте
        if (p.life <= 0) {
          parts.splice(i, 1);
          continue;
        }
        const a = Math.max(0, Math.min(1, p.life));
        ctx.beginPath();
        ctx.fillStyle = `rgba(34, 224, 255, ${0.85 * a})`;
        ctx.shadowColor = 'rgba(34, 224, 255, 0.9)';
        ctx.shadowBlur = 10;
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fill();
      }
      ctx.shadowBlur = 0;
      ctx.globalCompositeOperation = 'source-over';
      if (active || parts.length > 0) {
        raf = requestAnimationFrame(step);
      } else {
        raf = 0;
      }
    };

    // Активность по видимости Hero: появляется/гаснет плавно (CSS-opacity на канвасе).
    const io = new IntersectionObserver(
      (entries) => {
        const e = entries[0];
        if (!e) return;
        active = e.isIntersecting;
        if (active) {
          canvas.setAttribute('data-active', '');
          measure();
          if (!raf) raf = requestAnimationFrame(step);
        } else {
          canvas.removeAttribute('data-active'); // CSS плавно гасит, частицы дотухают
        }
      },
      { threshold: 0.05 },
    );
    io.observe(hero);
  })();
</script>
