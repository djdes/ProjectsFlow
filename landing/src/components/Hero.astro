---
import KanbanBoard from './KanbanBoard.tsx';

// Лендинг и SPA — один Express в prod, пути относительные.
const appBase = (import.meta.env.PUBLIC_APP_URL ?? '').replace(/\/+$/, '');

// Три ключевых пункта вместо описательного абзаца (по брифу владельца).
const points = [
  {
    key: 'llm',
    title: 'Подписка на Claude — уже внутри',
    text: 'Онлайн-доступ к ведущим LLM. Без VPN и без своих API-ключей — просто работаешь.',
  },
  {
    key: 'money',
    title: 'Прибыль и траты — понятным языком',
    text: 'Видно, сколько проект заработал и сколько потратил. Без таблиц и лишних терминов.',
  },
  {
    key: 'auto',
    title: 'Автоматизации из коробки',
    text: 'Автоулучшения, проверки безопасности и доска, где задачи выполняет AI-воркер.',
  },
];
---

<section class="hero" aria-labelledby="hero-title">
  <!-- Тихий ambient-слой: лёгкая координатная сетка + один мягкий цианный свет. -->
  <div class="hero__bg" aria-hidden="true">
    <div class="hero__grid grid-bg"></div>
    <div class="mesh-blob mesh-blob--magnetic hero__glow" data-magnetic-blob></div>
  </div>

  <div class="hero__wide">
    <!-- Notion-раскладка: центрированный лид сверху. -->
    <div class="hero__lede" data-reveal>
      <h1 id="hero-title" class="hero__title">
        Опиши идею — получи <span class="hero__kw"><span class="hero__kw-dot" aria-hidden="true"></span>готовый&nbsp;продукт</span>.
      </h1>

      <p class="hero__subtitle">
        Подписка на Claude уже внутри, проект на автопилоте, а прибыль и траты — понятным
        языком. Без VPN, своих ключей и лишней настройки.
      </p>

      <!-- Оффер + быстрый старт (email → регистрация). Анимированная приглашающая кнопка. -->
      <div class="hero__start">
        <p class="hero__offer">
          <span class="hero__offer-badge">1 час бесплатно</span>
          <span class="hero__offer-text">Первый час на <b>Прайме</b> — без карты. Первый результат — в первый час.</span>
        </p>

        <form class="hero__form" data-auth-anon data-hero-start data-app-base={appBase}>
          <input
            type="email"
            name="email"
            class="hero__email"
            placeholder="Твой e-mail"
            autocomplete="email"
            aria-label="E-mail для старта"
          />
          <button type="submit" class="pf-btn pf-btn--primary pf-btn--lg pf-btn--invite">
            Начать бесплатно
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" class="hero__arrow" aria-hidden="true">
              <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </button>
        </form>
        <a href={`${appBase}/login`} data-auth-anon class="hero__login">Уже есть аккаунт? Войти</a>

        <!-- Authed (скрыто изначально; BaseLayout выставит data-auth="authed"). -->
        <a
          href={`${appBase}/`}
          data-auth-authed
          class="pf-btn pf-btn--primary pf-btn--lg pf-btn--invite hero__authed"
        >
          Открыть приложение
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" class="hero__arrow" aria-hidden="true">
            <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </a>

        <div class="hero__promises">
          <span class="hero__promise">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M4 10.5l4 4 8-9" stroke-linecap="round" stroke-linejoin="round" /></svg>
            Старт без карты
          </span>
          <span class="hero__promise hero__promise--key">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M12 2.5l7 3v5.5c0 5-3.2 8.6-7 10.5-3.8-1.9-7-5.5-7-10.5V5.5l7-3z" stroke-linecap="round" stroke-linejoin="round" /><path d="M9 12l2 2 4-4.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
            Не&nbsp;зашло — вернём деньги
          </span>
          <span class="hero__promise">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M4 10.5l4 4 8-9" stroke-linecap="round" stroke-linejoin="round" /></svg>
            Проект остаётся твоим
          </span>
        </div>
      </div>
    </div>

    <!-- Крупная «сцена» продукта под лидом — как hero-скрин в Notion. ЕДИНСТВЕННАЯ
         интерактивная доска: перетащи задачу на «Воркер» — AI берёт её в работу. -->
    <div class="hero__stage" data-reveal style="--reveal-delay: 120ms">
      <!-- Иконки-бейджи + линии движения/«ветер»/искры вокруг скрина (как у Notion). Десктоп, декор. -->
      <div class="hero__stickers" aria-hidden="true">
        <span class="hero__sticker hero__sticker--v" style="top: -1.7rem; left: 1%; --rot: -10deg; --d: 0s">
          <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9z" /></svg>
        </span>
        <span class="hero__sticker hero__sticker--b" style="top: -2rem; right: 5%; --rot: 8deg; --d: -2.4s">
          <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M23 6l-9.5 9.5-5-5L1 18" /><path d="M17 6h6v6" /></svg>
        </span>
        <span class="hero__sticker hero__sticker--g" style="top: 40%; left: -1.8rem; --rot: -7deg; --d: -3.6s">
          <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.7" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg>
        </span>
        <span class="hero__sticker hero__sticker--a" style="bottom: 12%; right: -1.6rem; --rot: 9deg; --d: -1.4s">
          <svg viewBox="0 0 24 24" fill="#fff"><path d="M12 2.6l1.9 5.9h6.2l-5 3.6 1.9 5.9-5-3.6-5 3.6 1.9-5.9-5-3.6h6.2z" /></svg>
        </span>

        <span class="hero__doodle hero__doodle--wind" style="top: -1.9rem; left: 15%; --d: 0s">
          <svg viewBox="0 0 46 26" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M2 8h22a5 5 0 10-5-6" /><path d="M2 15h30a5 5 0 11-5 7" /><path d="M2 22h15" /></svg>
        </span>
        <span class="hero__doodle hero__doodle--spark" style="top: -2.4rem; right: 16%; --d: -1.5s">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 3v6M12 15v6M3 12h6M15 12h6" /></svg>
        </span>
        <span class="hero__doodle hero__doodle--speed" style="top: 32%; right: -2rem; --d: -0.8s">
          <svg viewBox="0 0 34 22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M2 5h18M8 11h22M2 17h12" /></svg>
        </span>
        <span class="hero__doodle hero__doodle--arc" style="bottom: 1%; left: 9%; --d: -2s">
          <svg viewBox="0 0 44 22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M2 20C10 4 34 4 42 20" /></svg>
        </span>
      </div>

      <div class="hero__stage-frame">
        <KanbanBoard client:visible />
      </div>
      <p class="hero__showcase-cap">
        Перетащи задачу на <b>«Воркер»</b> — или просто нажми. AI возьмёт её в работу.
      </p>
    </div>

    <!-- 3 ключевых пункта — спокойный ряд под сценой. -->
    <ul class="hero__points">
      {
        points.map((p) => (
          <li class="hero__point" data-reveal>
            <span class="hero__point-ic" aria-hidden="true">
              {p.key === 'llm' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
                  <path d="M13 3 4 14h7l-1 7 9-11h-7l1-7Z" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              )}
              {p.key === 'money' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
                  <path d="M4 19V9m5 10V5m5 14v-6m5 6V8" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              )}
              {p.key === 'auto' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
                  <circle cx="12" cy="12" r="3.2" />
                  <path
                    d="M12 3v2.5M12 18.5V21M3 12h2.5M18.5 12H21M5.6 5.6l1.8 1.8M16.6 16.6l1.8 1.8M18.4 5.6l-1.8 1.8M7.4 16.6l-1.8 1.8"
                    stroke-linecap="round"
                  />
                </svg>
              )}
            </span>
            <span class="hero__point-body">
              <span class="hero__point-title">{p.title}</span>
              <span class="hero__point-text">{p.text}</span>
            </span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    /* Меньше воздуха сверху под навбаром; низ — в одном ритме с секциями (--section-y). */
    padding-top: clamp(1.5rem, 4vw, 3rem);
    padding-bottom: var(--section-y);
  }

  /* --- Тихий ambient --- */
  .hero__bg { position: absolute; inset: 0; z-index: -20; pointer-events: none; }
  .hero__grid { position: absolute; inset: 0; }
  .hero__glow {
    width: 620px; height: 620px;
    background: var(--accent);
    top: -260px; right: -120px;
    opacity: 0.12;
  }

  /* --- Раскладка (Notion: центрированный лид + крупная сцена ниже) --- */
  .hero__wide {
    position: relative;
    width: 100%;
    /* Та же ширина и боковые поля, что и у .pf-container — край Hero совпадает с
       навбаром и всеми секциями ниже (единая ширина блоков). */
    max-width: var(--container);
    margin-inline: auto;
    padding-inline: clamp(1rem, 4vw, 1.5rem);
  }

  .hero__lede {
    max-width: 48rem;
    margin-inline: auto;
    text-align: center;
  }
  .hero__title {
    font-size: var(--fs-display);
    /* Чуть больше межстрочья — синяя пилюля не сталкивается со строкой «получи». */
    line-height: 1.22;
    letter-spacing: var(--tracking-tight);
    font-weight: 720;
    color: var(--text);
    text-wrap: balance;
  }
  /* Ключевое слово — синяя пилюля с ЧЁРНЫМ текстом внутри + синяя точка (как «● Think»). */
  .hero__kw {
    color: var(--text);
    background: #cfe4fb;
    padding: 0.06em 0.5em 0.12em;
    border-radius: 999px;
    white-space: nowrap;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
  }
  .hero__kw-dot {
    display: inline-block;
    width: 0.4em;
    height: 0.4em;
    margin-right: 0.36em;
    border-radius: 50%;
    background: #2383e2;
    vertical-align: 0.18em;
  }
  .hero__subtitle {
    margin: var(--sp-5) auto 0;
    max-width: 40rem;
    font-size: var(--fs-lg);
    line-height: var(--lh-normal);
    color: var(--muted);
    text-wrap: pretty;
  }

  /* --- Оффер + старт (центрированы под лидом) --- */
  .hero__start { margin-top: var(--sp-6); }
  .hero__offer {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--sp-2) var(--sp-3);
    max-width: 34rem;
    padding: var(--sp-3) var(--sp-4);
    border: 1px solid var(--accent-line);
    border-radius: var(--r);
    background: var(--accent-soft);
    font-size: var(--fs-sm);
    color: var(--text);
    line-height: var(--lh-snug);
    text-align: left;
  }
  .hero__offer b { color: var(--accent-deep); font-weight: 700; }
  .hero__offer-text { flex: 1 1 12rem; min-width: 0; }
  .hero__offer-badge {
    flex: none;
    padding: var(--sp-1) var(--sp-3);
    border-radius: var(--r-full);
    background: var(--grad-accent);
    color: var(--accent-ink);
    font-size: var(--fs-xs);
    font-weight: 800;
    white-space: nowrap;
  }

  .hero__form {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--sp-2);
    max-width: 30rem;
    margin: var(--sp-4) auto 0;
  }
  .hero__email {
    flex: 1 1 220px;
    min-width: 0;
    height: 50px;
    padding-inline: var(--sp-4);
    border-radius: var(--r-sm);
    border: 1px solid var(--line-strong);
    background: var(--surface);
    color: var(--text);
    font-size: var(--fs-base);
    font-family: inherit;
    text-align: left;
    transition: border-color var(--dur-fast) var(--ease), box-shadow var(--dur-fast) var(--ease);
  }
  .hero__email::placeholder { color: var(--dim); }
  .hero__email:focus-visible {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }
  .hero__authed { display: none; margin-top: var(--sp-4); }
  .hero__arrow { width: 16px; height: 16px; }
  .hero__login {
    display: inline-block;
    margin-top: var(--sp-3);
    font-size: var(--fs-sm);
    color: var(--muted);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color var(--dur-fast) var(--ease), border-color var(--dur-fast) var(--ease);
  }
  .hero__login:hover { color: var(--accent); border-color: var(--accent-line); }
  /* Снятие риска у самой кнопки (Хормози): три обещания, гарантия возврата — выделена. */
  .hero__promises {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--sp-2);
    margin-top: var(--sp-5);
  }
  .hero__promise {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 10px;
    border-radius: var(--r-full);
    border: 1px solid var(--line);
    background: var(--surface);
    font-size: var(--fs-sm);
    color: var(--muted);
  }
  .hero__promise svg { width: 14px; height: 14px; flex: none; color: var(--signal); }
  .hero__promise--key {
    border-color: var(--accent);
    background: var(--accent-soft);
    color: var(--accent-deep);
    font-weight: 700;
  }
  .hero__promise--key svg { color: var(--accent-deep); }

  /* --- Сцена продукта: крупный «hero-скрин» как в Notion --- */
  .hero__stage {
    position: relative;
    margin-top: clamp(2rem, 5vw, 3.5rem);
    max-width: 940px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-3);
  }
  /* Иконки-бейджи + декоративные линии вокруг скрина продукта (десктоп). */
  .hero__stickers { position: absolute; inset: 0; pointer-events: none; z-index: 3; display: none; }
  @media (min-width: 900px) { .hero__stickers { display: block; } }

  /* Бейдж: цветной круг + белая иконка, лёгкий наклон и плавное парение. */
  .hero__sticker {
    position: absolute;
    display: grid;
    place-items: center;
    width: clamp(46px, 3.4vw, 60px);
    height: clamp(46px, 3.4vw, 60px);
    border-radius: 50%;
    background: var(--bg, #2f6fd4);
    box-shadow:
      inset 0 1.5px 0 rgba(255, 255, 255, 0.45),
      0 14px 26px -8px var(--glow, rgba(11, 18, 32, 0.30)),
      0 3px 8px rgba(11, 18, 32, 0.14);
    transform: rotate(var(--rot, -6deg));
    animation: hero-float 6.5s var(--d, 0s) ease-in-out infinite;
    will-change: transform;
  }
  .hero__sticker svg { width: 52%; height: 52%; }
  .hero__sticker--v { --bg: linear-gradient(150deg, #9b7bff, #6d4bf5); --glow: rgba(124, 92, 255, 0.5); }
  .hero__sticker--b { --bg: linear-gradient(150deg, #5aa9ff, #2f6fd4); --glow: rgba(47, 111, 212, 0.5); }
  .hero__sticker--g { --bg: linear-gradient(150deg, #43d6a0, #12a97b); --glow: rgba(18, 169, 123, 0.5); }
  .hero__sticker--a { --bg: linear-gradient(150deg, #ffce5a, #ff9d2e); --glow: rgba(255, 157, 46, 0.5); }

  /* Декоративные линии/искры («ветер», speed-lines, звёздочки) — тонкие, слегка «дышат». */
  .hero__doodle { position: absolute; }
  .hero__doodle svg { display: block; }
  .hero__doodle--wind { width: 46px; color: var(--accent); opacity: 0.75; }
  .hero__doodle--spark { width: 22px; color: #7c5cff; }
  .hero__doodle--speed { width: 34px; color: #ff9d2e; opacity: 0.85; }
  .hero__doodle--arc { width: 44px; color: var(--accent); opacity: 0.6; }

  @keyframes hero-float {
    0%, 100% { transform: translateY(0) rotate(var(--rot, -6deg)); }
    50% { transform: translateY(-10px) rotate(calc(var(--rot, -6deg) * -1)); }
  }
  @media (prefers-reduced-motion: no-preference) {
    .hero__doodle--wind, .hero__doodle--speed { animation: hero-shimmer 4s var(--d, 0s) ease-in-out infinite; }
    .hero__doodle--spark { animation: hero-twinkle 3.6s var(--d, 0s) ease-in-out infinite; }
    .hero__doodle--arc { animation: hero-float 7s var(--d, 0s) ease-in-out infinite; }
  }
  @keyframes hero-shimmer {
    0%, 100% { transform: translateX(0); opacity: 0.7; }
    50% { transform: translateX(5px); opacity: 1; }
  }
  @keyframes hero-twinkle {
    0%, 100% { transform: scale(1) rotate(0deg); opacity: 0.9; }
    50% { transform: scale(1.25) rotate(45deg); opacity: 0.45; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__sticker, .hero__doodle { animation: none; }
  }
  /* Мягкая «парящая» тень со всех сторон + лёгкий hover-подъём (как рамки скринов ниже). */
  .hero__stage-frame {
    width: 100%;
    border-radius: var(--r-lg);
    box-shadow:
      0 1px 2px rgba(11, 18, 32, 0.05),
      0 12px 30px -10px rgba(11, 18, 32, 0.12),
      0 40px 70px -30px rgba(11, 18, 32, 0.22);
    transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
  }
  @media (prefers-reduced-motion: no-preference) {
    .hero__stage-frame:hover {
      transform: translateY(-4px);
      box-shadow:
        0 2px 4px rgba(11, 18, 32, 0.06),
        0 18px 40px -12px rgba(11, 18, 32, 0.14),
        0 60px 100px -40px rgba(11, 18, 32, 0.26);
    }
  }
  /* Тень «парения» даёт рамка; у самой доски её гасим, чтобы не двоилась. */
  .hero__stage-frame :global(.kb2) { box-shadow: none; max-width: 100%; }
  .hero__showcase-cap { font-size: var(--fs-sm); color: var(--muted); text-align: center; max-width: 30rem; }
  .hero__showcase-cap b { color: var(--accent); font-weight: 700; }

  /* --- 3 ключевых пункта: ряд под сценой --- */
  .hero__points {
    list-style: none;
    margin: clamp(2.5rem, 5vw, 4rem) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-6);
  }
  @media (min-width: 760px) {
    .hero__points { grid-template-columns: repeat(3, 1fr); gap: var(--sp-8); }
  }
  .hero__point { display: flex; gap: var(--sp-3); align-items: flex-start; }
  .hero__point-ic {
    flex: none;
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: var(--r-sm);
    border: 1px solid var(--accent-line);
    background: var(--accent-soft);
    color: var(--accent);
  }
  .hero__point-ic svg { width: 20px; height: 20px; }
  .hero__point-body { display: flex; flex-direction: column; gap: 2px; }
  .hero__point-title { font-size: var(--fs-base); font-weight: 650; color: var(--text); }
  .hero__point-text { font-size: var(--fs-sm); color: var(--muted); line-height: var(--lh-snug); }
</style>

<script>
  // Лёгкий параллакс мягкого cyan-света за курсором. Уважает reduced-motion.
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduceMotion) {
    const blob = document.querySelector<HTMLElement>('[data-magnetic-blob]');
    if (blob) {
      const MAX = 50;
      window.addEventListener(
        'pointermove',
        (e: PointerEvent) => {
          const nx = (e.clientX / window.innerWidth) * 2 - 1;
          const ny = (e.clientY / window.innerHeight) * 2 - 1;
          blob.style.setProperty('--blob-x', `${nx * MAX}px`);
          blob.style.setProperty('--blob-y', `${ny * MAX}px`);
        },
        { passive: true },
      );
    }
  }
</script>

<script>
  // Быстрый старт: e-mail из героя → на регистрацию с предзаполнением. Без e-mail — просто регистрация.
  const form = document.querySelector<HTMLFormElement>('[data-hero-start]');
  if (form) {
    const base = (form.getAttribute('data-app-base') ?? '').replace(/\/+$/, '');
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const email = new FormData(form).get('email');
      const q = typeof email === 'string' && email.includes('@') ? `?email=${encodeURIComponent(email)}` : '';
      window.location.href = `${base}/register${q}`;
    });
  }
</script>
