---
import HeroSceneGate from './HeroSceneGate.tsx';

// Лендинг и SPA — один Express в prod, пути относительные.
const appBase = (import.meta.env.PUBLIC_APP_URL ?? '').replace(/\/+$/, '');
---

<section class="hero" aria-labelledby="hero-title">
  <!-- Ambient-слой = статичный «постер» в стиле сцены: координатная сетка + цианово-зелёные
       свечения. Виден всегда; на мобиле/при reduced-motion заменяет 3D-сцену. -->
  <div class="hero__bg" aria-hidden="true">
    <div class="hero__grid grid-bg"></div>
    <div class="mesh-blob mesh-blob--magnetic hero__glow-cyan" data-magnetic-blob></div>
    <div class="mesh-blob hero__glow-green"></div>
    <div class="hero__vignette"></div>
  </div>

  <!-- 3D data-tower: грузится только на десктопе с motion и поддержкой WebGL.
       client:media гарантирует, что на узких экранах chunk three.js не скачивается. -->
  <div class="hero__scene" aria-hidden="true">
    <HeroSceneGate client:media="(min-width: 1024px)" />
  </div>

  <div class="pf-container hero__inner">
    <div class="hero__col">
      <span class="pf-eyebrow">
        <span class="pf-dot"></span>
        <span class="pf-mono">for vibe-coders</span>
      </span>

      <h1 id="hero-title" class="hero__title">
        Бросай задачи — <span class="pf-grad">воркер пишет код</span>.<br />
        Ты на драйве.
      </h1>

      <p class="hero__sub">
        Доска задач для твоих проектов со встроенным AI-воркером, автоматизацией и
        финучётом. Кидаешь задачу в колонку <span class="pf-mono hero__accent">worker</span> —
        она выполняется по нашей подписке. Без возни с инфрой и чужими лимитами.
      </p>

      <div class="hero__cta">
        {/* Anonymous (по умолчанию). Скрипт в BaseLayout заменит на «Открыть приложение». */}
        <a href={`${appBase}/register`} data-auth-anon class="pf-btn pf-btn--primary pf-btn--lg">
          Начать бесплатно
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" class="hero__arrow" aria-hidden="true">
            <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </a>
        <a href={`${appBase}/login`} data-auth-anon class="pf-btn pf-btn--ghost pf-btn--lg">Войти</a>
        {/* Authed (скрыто изначально). */}
        <a href={`${appBase}/`} data-auth-authed class="pf-btn pf-btn--primary pf-btn--lg hero__authed">
          Открыть приложение
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" class="hero__arrow" aria-hidden="true">
            <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </a>
      </div>

      <!-- Псевдо-терминал — фирменный визуал dev-cool. -->
      <div class="pf-term hero__term" data-reveal style="--reveal-delay: 200ms">
        <div class="pf-term__bar">
          <i class="pf-term__light pf-term__light--r"></i>
          <i class="pf-term__light pf-term__light--y"></i>
          <i class="pf-term__light pf-term__light--g"></i>
          <span class="pf-term__title">~/projects/my-saas — projectsflow</span>
        </div>
        <div class="pf-term__body"><span class="pf-term__c"># кидаешь задачу воркеру</span>
<span class="pf-term__p">pf</span> <span class="pf-term__v">task add</span> <span class="pf-term__w">"добавь dark mode на дашборд"</span> --col worker
<span class="pf-term__c">→ воркер взял в работу · Claude Opus · автодеплой on</span>

<span class="pf-term__p">pf</span> <span class="pf-term__v">finance</span> --project my-saas
<span class="pf-term__c">→ расход за месяц: 1 240 ₽ · по подписке Прайм</span></div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    min-height: calc(100dvh - 60px);
    display: flex;
    align-items: center;
  }

  /* --- Ambient «постер» --- */
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: -20;
    pointer-events: none;
  }
  .hero__grid {
    position: absolute;
    inset: 0;
  }
  .hero__glow-cyan {
    width: 560px;
    height: 560px;
    background: var(--accent-deep);
    top: -180px;
    left: 50%;
    margin-left: -280px;
    opacity: 0.4;
  }
  .hero__glow-green {
    width: 380px;
    height: 380px;
    background: #0e7a4d;
    top: 360px;
    right: -120px;
    opacity: 0.26;
  }
  .hero__vignette {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    height: 12rem;
    background: linear-gradient(to bottom, transparent, var(--bg));
  }

  /* --- 3D-сцена --- */
  .hero__scene {
    position: absolute;
    inset: 0;
    z-index: -10;
    pointer-events: none;
    -webkit-mask-image: linear-gradient(to bottom, #000 0%, #000 72%, transparent 100%);
    mask-image: linear-gradient(to bottom, #000 0%, #000 72%, transparent 100%);
  }

  /* --- Контент --- */
  .hero__inner {
    position: relative;
    padding-block: clamp(2.5rem, 6vw, 4.5rem);
  }
  .hero__col {
    width: 100%;
    max-width: 640px;
  }
  .hero__title {
    margin-top: var(--sp-6);
    font-size: var(--fs-display);
    line-height: var(--lh-tight);
    letter-spacing: var(--tracking-tight);
    font-weight: 800;
    color: var(--text);
    text-wrap: balance;
  }
  .hero__sub {
    margin-top: var(--sp-6);
    max-width: 34rem;
    color: var(--muted);
    font-size: var(--fs-lg);
    line-height: var(--lh-normal);
  }
  .hero__accent { color: var(--accent); }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    margin-top: var(--sp-8);
  }
  .hero__authed { display: none; }
  .hero__arrow { width: 16px; height: 16px; }
  .hero__term {
    margin-top: var(--sp-12);
    max-width: 600px;
  }

  /* На десктопе текст занимает ~58% ширины — справа дышит 3D-башня. */
  @media (min-width: 1024px) {
    .hero__col { max-width: 58%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__term { opacity: 1; }
  }
</style>

<script>
  // Лёгкий параллакс cyan-свечения за курсором (как было на main). Уважает reduced-motion.
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduceMotion) {
    const blob = document.querySelector<HTMLElement>('[data-magnetic-blob]');
    if (blob) {
      const MAX = 70;
      window.addEventListener(
        'pointermove',
        (e: PointerEvent) => {
          const nx = (e.clientX / window.innerWidth) * 2 - 1;
          const ny = (e.clientY / window.innerHeight) * 2 - 1;
          // .mesh-blob--magnetic анимирует transform через эти переменные (soft 1.2s easing).
          blob.style.setProperty('--blob-x', `${nx * MAX}px`);
          blob.style.setProperty('--blob-y', `${ny * MAX}px`);
        },
        { passive: true },
      );
    }
  }
</script>
