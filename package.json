{
  "name": "projectsflow",
  "version": "0.1.0",
  "private": true,
  "description": "ProjectsFlow — платформа управления проектами + лендинг",
  "type": "module",
  "workspaces": [
    "client",
    "server",
    "landing",
    "mcp-server"
  ],
  "scripts": {
    "dev": "concurrently -k -n client,server -c blue,green \"npm:dev -w @projectsflow/client\" \"npm:dev -w @projectsflow/server\"",
    "dev:client": "npm run dev -w @projectsflow/client",
    "dev:server": "npm run dev -w @projectsflow/server",
    "dev:landing": "npm run dev -w @projectsflow/landing",
    "build": "npm run build -w @projectsflow/client && npm run build -w @projectsflow/landing && npm run build -w @projectsflow/server",
    "build:client": "npm run build -w @projectsflow/client",
    "build:server": "npm run build -w @projectsflow/server",
    "build:landing": "npm run build -w @projectsflow/landing",
    "typecheck": "npm run typecheck -w @projectsflow/client",
    "lint": "npm run lint -w @projectsflow/client",
    "start": "node server/dist/index.js",
    "db:migrate": "node --env-file=.env scripts/migrate.mjs",
    "db:seed-admin": "node --env-file=.env scripts/seed-admin.mjs",
    "verify:project-views": "node scripts/verify-project-page-views.mjs",
    "deploy": "node scripts/deploy.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "playwright-core": "^1.61.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
