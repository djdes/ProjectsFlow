# ===========================================================
# ProjectsFlow — environment variables
# Copy to .env and fill in. .env is gitignored.
# ===========================================================

# --- App ---
NODE_ENV=development
PORT=4317

# Базовый URL приложения (app.projectsflow.ru в проде, http://localhost:5173 в dev).
# Используется в magic-link письмах: APP_URL/auth/magic/consume?token=...
APP_URL=http://localhost:5173
BRAND_NAME=ProjectsFlow

# --- CORS ---
# Список origin'ов через запятую, которым можно стучаться в /api с credentials.
# В dev: лендинг на 4321, client на 5173.
# В prod: https://projectsflow.ru (лендинг).
CORS_ORIGINS=http://localhost:4321,http://localhost:5173

# --- Local dev DB (Drizzle) ---
# Локальный MySQL/MariaDB на dev-машине.
DATABASE_URL=mysql://projectsflow:<password>@127.0.0.1:3306/projectsflow

# --- Session ---
SESSION_COOKIE_NAME=pf_session
SESSION_TTL_DAYS=30
# В prod: .projectsflow.ru (чтобы кука работала между landing и app subdomains).
# В dev: оставь пустым.
SESSION_COOKIE_DOMAIN=

# --- Magic-link auth ---
MAGIC_TOKEN_TTL_MIN=15
MAGIC_RATE_LIMIT_WINDOW_MIN=10
MAGIC_RATE_LIMIT_MAX=5

# --- SMTP (для magic-link писем) ---
# В dev: оставь пустым — письма пойдут в stdout (ConsoleEmailSender).
# В prod: задаются обязательно, иначе сервер не стартанёт.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="ProjectsFlow <noreply@projectsflow.ru>"

# --- Secrets vault (AES-256-GCM) ---
# 32-байтный ключ в base64. Сгенерировать:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SECRETS_MASTER_KEY=

# --- GitHub OAuth (Device Flow) ---
GITHUB_CLIENT_ID=

# --- Landing build-time vars (Astro PUBLIC_* экспонируется в браузер) ---
# Базовый URL API, к которому стучится email-форма с лендинга.
PUBLIC_API_BASE_URL=http://localhost:4317/api
# URL платформы — кнопка "Войти" в навигации лендинга.
PUBLIC_APP_URL=http://localhost:5173

# --- Prod DB (используется только deploy-скриптами + future production) ---
DB_SOCKET=
DB_HOST=projectsflow.ru
DB_PORT=3306
DB_USER=projectsflow
DB_PASSWORD=
DB_NAME=projectsflow
DB_CONNECTION_LIMIT=10

# --- SSH / Deploy (scripts/deploy.mjs) ---
SSH_HOST=projectsflow.ru
SSH_PORT_LOCAL=22
SSH_PORT_REMOTE=50222
SSH_USER=projectsflow
SSH_PASSWORD=
DEPLOY_PATH=/var/www/projectsflow/data/www/projectsflow.ru
# Лендинг кладётся отдельно — nginx раздаёт его на projectsflow.ru/, минуя Node.
LANDING_DEPLOY_PATH=/var/www/projectsflow/data/www/projectsflow.ru/landing

# --- Git (bare repo на сервере) ---
GIT_REMOTE_PATH=/var/www/projectsflow/data/git/projectsflow.git
