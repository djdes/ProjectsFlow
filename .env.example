# ===========================================================
# ProjectsFlow — environment variables
# Copy to .env and fill in. .env is gitignored.
# ===========================================================

# --- App ---
NODE_ENV=development
# Express listens on this port. nginx должен проксировать сюда.
PORT=4317

# --- MySQL / MariaDB ---
# Приоритет: если задан DB_SOCKET — используется unix-сокет (только на сервере).
# На сервере (внутри VPS) — этот вариант, юзер projectsflow@localhost доступен только так:
#   DB_SOCKET=/run/mysqld/mysqld.sock
# Локально с рабочей станции, когда remote разрешён:
#   DB_HOST=projectsflow.ru
#   DB_PORT=3306
DB_SOCKET=
DB_HOST=projectsflow.ru
DB_PORT=3306
DB_USER=projectsflow
DB_PASSWORD=
DB_NAME=projectsflow
DB_CONNECTION_LIMIT=10

# --- SSH / Deploy (only used by scripts/deploy.mjs) ---
SSH_HOST=projectsflow.ru
SSH_PORT_LOCAL=22
SSH_PORT_REMOTE=50222
SSH_USER=projectsflow
SSH_PASSWORD=
# Целевая директория на сервере (FastPanel docroot)
DEPLOY_PATH=/var/www/projectsflow/data/www/projectsflow.ru

# --- Git (создаётся на сервере как bare repo) ---
GIT_REMOTE_PATH=/var/www/projectsflow/data/git/projectsflow.git
