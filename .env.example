# ===========================================================
# ProjectsFlow — environment variables
# Copy to .env and fill in. .env is gitignored.
# ===========================================================

# --- App ---
NODE_ENV=development
PORT=4317

# --- Local dev DB (Drizzle) ---
# Локальный MySQL/MariaDB на dev-машине. Создай БД и юзера:
#   CREATE DATABASE projectsflow CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
#   CREATE USER 'projectsflow'@'localhost' IDENTIFIED BY '<password>';
#   GRANT ALL ON projectsflow.* TO 'projectsflow'@'localhost';
DATABASE_URL=mysql://projectsflow:<password>@127.0.0.1:3306/projectsflow

# --- Session ---
SESSION_COOKIE_NAME=pf_session
SESSION_TTL_DAYS=30

# --- GitHub OAuth (Device Flow) ---
# Registration: github.com/settings/developers → New OAuth App → toggle "Enable Device Flow".
# Client Secret НЕ нужен для device flow.
GITHUB_CLIENT_ID=

# --- Prod DB (используется только deploy-скриптами + future production) ---
# На сервере приоритет у DB_SOCKET=/run/mysqld/mysqld.sock — юзер ходит через unix-сокет.
DB_SOCKET=
DB_HOST=projectsflow.ru
DB_PORT=3306
DB_USER=projectsflow
DB_PASSWORD=
DB_NAME=projectsflow
DB_CONNECTION_LIMIT=10

# --- SSH / Deploy (scripts/deploy.mjs) ---
SSH_HOST=projectsflow.ru
SSH_PORT_LOCAL=22
SSH_PORT_REMOTE=50222
SSH_USER=projectsflow
SSH_PASSWORD=
DEPLOY_PATH=/var/www/projectsflow/data/www/projectsflow.ru

# --- Git (bare repo на сервере) ---
GIT_REMOTE_PATH=/var/www/projectsflow/data/git/projectsflow.git

# --- App base URL (для invite-ссылок в письмах) ---
APP_URL=http://localhost:5173

# --- SMTP (отправка invite-писем; пусто ⇒ письма логируются в консоль) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# false ⇒ принимать самоподписанный cert MTA (self-hosted почтовик). По умолчанию строгая проверка.
SMTP_TLS_REJECT_UNAUTHORIZED=true

# --- Root/admin (сидится scripts/seed-admin.mjs) ---
ADMIN_EMAIL=admin@projectsflow.ru
ADMIN_PASSWORD=

# --- Telegram multi-user notifications (опционально) ---
# Бот @projectsflow_bot — отдельный от @RalphBot (тот в Ralph-диспетчере). Если этих
# переменных нет — все TG-эндпоинты деградируют (connected=false, send → error/410).
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=projectsflow_bot
# 32+ случайных символов для X-Telegram-Bot-Api-Secret-Token. Без него webhook принимает
# что угодно — в проде ОБЯЗАТЕЛЬНО задать.
TELEGRAM_WEBHOOK_SECRET=
# Публичный URL вебхука; setWebhook вызовется при старте, только если задан вместе с token+secret.
TELEGRAM_WEBHOOK_URL=https://projectsflow.ru/api/telegram/webhook
# Опциональный relay для Telegram API: если хостинг блокирует часть подсетей
# api.telegram.org (типично для RU-провайдеров → ETIMEDOUT на setWebhook/sendMessage),
# поднимаем CF-worker / nginx reverse-proxy и указываем его base URL. Без env —
# прямой канал на https://api.telegram.org.
TELEGRAM_API_BASE_URL=
# HTTP(S)-proxy для исходящих к Telegram (формат http://user:pass@host:port).
# Самый простой способ обойти провайдерскую блокировку. Применяется ко всем запросам
# к Telegram API (setWebhook, sendMessage). Без env — прямой канал.
TELEGRAM_HTTP_PROXY=
