# ===========================================================
# ProjectsFlow — environment variables
# Copy to .env and fill in. .env is gitignored.
# ===========================================================

# --- App ---
NODE_ENV=development
PORT=4317

# --- Local dev DB (Drizzle) ---
# Локальный MySQL/MariaDB на dev-машине. Создай БД и юзера:
#   CREATE DATABASE projectsflow CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
#   CREATE USER 'projectsflow'@'localhost' IDENTIFIED BY '<password>';
#   GRANT ALL ON projectsflow.* TO 'projectsflow'@'localhost';
DATABASE_URL=mysql://projectsflow:<password>@127.0.0.1:3306/projectsflow

# --- Session ---
SESSION_COOKIE_NAME=pf_session
SESSION_TTL_DAYS=30

# --- GitHub OAuth (Device Flow) ---
# Registration: github.com/settings/developers → New OAuth App → toggle "Enable Device Flow".
# Client Secret НЕ нужен для device flow.
GITHUB_CLIENT_ID=

# --- Prod DB (используется только deploy-скриптами + future production) ---
# На сервере приоритет у DB_SOCKET=/run/mysqld/mysqld.sock — юзер ходит через unix-сокет.
DB_SOCKET=
DB_HOST=projectsflow.ru
DB_PORT=3306
DB_USER=projectsflow
DB_PASSWORD=
DB_NAME=projectsflow
DB_CONNECTION_LIMIT=10

# --- SSH / Deploy (scripts/deploy.mjs) ---
SSH_HOST=projectsflow.ru
SSH_PORT_LOCAL=22
SSH_PORT_REMOTE=50222
SSH_USER=projectsflow
SSH_PASSWORD=
DEPLOY_PATH=/var/www/projectsflow/data/www/projectsflow.ru

# --- Git (bare repo на сервере) ---
GIT_REMOTE_PATH=/var/www/projectsflow/data/git/projectsflow.git

# --- App base URL (для invite-ссылок в письмах) ---
APP_URL=http://localhost:5173

# --- SMTP (отправка invite-писем; пусто ⇒ письма логируются в консоль) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# false ⇒ принимать самоподписанный cert MTA (self-hosted почтовик). По умолчанию строгая проверка.
SMTP_TLS_REJECT_UNAUTHORIZED=true

# --- Root/admin (сидится scripts/seed-admin.mjs) ---
ADMIN_EMAIL=admin@projectsflow.ru
ADMIN_PASSWORD=

# --- Telegram multi-user notifications (опционально) ---
# Бот @projectsflow_bot — отдельный от @RalphBot (тот в Ralph-диспетчере). Если этих
# переменных нет — все TG-эндпоинты деградируют (connected=false, send → error/410).
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=projectsflow_bot
# 32+ случайных символов для X-Telegram-Bot-Api-Secret-Token. Без него webhook принимает
# что угодно — в проде ОБЯЗАТЕЛЬНО задать.
TELEGRAM_WEBHOOK_SECRET=
# Публичный URL вебхука; setWebhook вызовется при старте, только если задан вместе с token+secret.
TELEGRAM_WEBHOOK_URL=https://projectsflow.ru/api/telegram/webhook
# Опциональный relay для Telegram API: если хостинг блокирует часть подсетей
# api.telegram.org (типично для RU-провайдеров → ETIMEDOUT на setWebhook/sendMessage),
# поднимаем CF-worker / nginx reverse-proxy и указываем его base URL. Без env —
# прямой канал на https://api.telegram.org.
TELEGRAM_API_BASE_URL=
# HTTP(S)-proxy для исходящих к Telegram (формат http://user:pass@host:port).
# Самый простой способ обойти провайдерскую блокировку. Применяется ко всем запросам
# к Telegram API (setWebhook, sendMessage). Без env — прямой канал.
TELEGRAM_HTTP_PROXY=
# TELEGRAM_MODE = webhook | polling | auto (default).
# - webhook: setWebhook(TELEGRAM_WEBHOOK_URL) — Telegram сам шлёт нам апдейты.
# - polling: getUpdates loop — сами тащим через TELEGRAM_HTTP_PROXY. Нужно когда хостинг
#   блокирует inbound от Telegram (типично RU-провайдеры).
# - auto: webhook если задан URL+SECRET, иначе polling.
TELEGRAM_MODE=auto

# --- Telegram voice → task via Groq Speech-to-Text (optional) ---
# Bare voice messages from linked work groups are transcribed, echoed to the group, and passed
# to the normal task composer. Keep GROQ_API_KEY only in the environment; never commit it.
GROQ_API_KEY=
GROQ_API_BASE_URL=https://api.groq.com
# Optional outbound proxy. When empty, the server reuses TELEGRAM_HTTP_PROXY if it exists.
GROQ_HTTP_PROXY=
GROQ_VOICE_MODEL=whisper-large-v3-turbo
GROQ_VOICE_LANGUAGE=ru
# Groq free-tier upload limit is 25 MB. Increase only if the account limit allows it.
GROQ_VOICE_MAX_BYTES=26214400

# --- AI prompt-improvement (опционально) ---
# Email юзера — дефолтного диспетчера для AI-улучшений Inbox-задач (когда у задачи нет
# projectId). Должен совпадать с существующим юзером, у которого есть активный agent-токен
# и крутится Ralph-инстанс, поллящий pf_list_pending_ai_prompt_jobs.
# Если переменная пуста ИЛИ указывает на юзера без активного токена — сервер сам падает
# на фоллбэк: первый админ с активным agent-токеном (см. resolveDefaultAiDispatcher).
# Поэтому кнопка «AI» для Inbox-задач работает «из коробки», пока есть админ-диспетчер.
# Для project-task'ов используется dispatcher_user_id проекта (env не задействован).
# См. docs/superpowers/specs/2026-05-28-ai-prompt-improvement-design.md.
AI_PROMPT_DEFAULT_DISPATCHER_EMAIL=admin@projectsflow.ru

# --- Чат-виджет: поддержка (опционально) ---
# chat_id Telegram-чата поддержки, куда падают обращения из виджета (вкладка
# «Связаться с поддержкой»). Число; для групп — отрицательное (напр. -1001234567890).
# Бот @projectsflow_bot должен состоять в этом чате/группе.
# Если пусто/невалидно — fallback: обращение шлётся всем админам через их личную
# Telegram-привязку (см. SubmitSupportTicket). Тикет в БД (support_tickets) сохраняется
# в любом случае. Получить chat_id: добавить бота в чат и посмотреть update'ы, либо
# переслать сообщение из чата боту @getidsbot.
SUPPORT_TELEGRAM_CHAT_ID=

# --- Лимиты диспетчера (usage) — оверрайд МЕСЯЧНОГО лимита (опционально) ---
# Стоимость работы диспетчера метерится на инициатора (кто отдал воркеру / нажал AI) и
# гейтится по двум окнам: недельное (7д) = месяц/4, 5-часовое = недельное × 0.4.
# Без env — дефолт из PLAN_MONTHLY_USD: Prime $50/мес (5000 ₽), VIP $100/мес (10000 ₽).
# Для теста поставь крошечный месячный лимит (напр. 2) — блок ловится почти сразу. USD.
USAGE_PRIME_MONTHLY_USD=
USAGE_VIP_MONTHLY_USD=
